[{"n":"Sputnik 1","ag":"Soviet Union","ds":"Earth orbit","la":1957,"du":"92 days","st":"Success","fa":"First artificial satellite ever launched, triggering the Space Race and proving orbital mechanics","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b7/%D0%9F%D0%B5%D1%80%D0%B2%D1%8B%D0%B9_%D0%B2_%D0%BC%D0%B8%D1%80%D0%B5_%D0%B8%D1%81%D0%BA%D1%83%D1%81%D1%81%D1%82%D0%B2%D0%B5%D0%BD%D0%BD%D1%8B%D0%B9_%D1%81%D0%BF%D1%83%D1%82%D0%BD%D0%B8%D0%BA_%D0%97%D0%B5%D0%BC%D0%BB%D0%B8.jpg/500px-%D0%9F%D0%B5%D1%80%D0%B2%D1%8B%D0%B9_%D0%B2_%D0%BC%D0%B8%D1%80%D0%B5_%D0%B8%D1%81%D0%BA%D1%83%D1%81%D1%81%D1%82%D0%B2%D0%B5%D0%BD%D0%BD%D1%8B%D0%B9_%D1%81%D0%BF%D1%83%D1%82%D0%BD%D0%B8%D0%BA_%D0%97%D0%B5%D0%BC%D0%BB%D0%B8.jpg"},{"n":"Explorer 1","ag":"NASA","ds":"Earth orbit","la":1958,"du":"12 years","st":"Success","fa":"First US satellite; discovered the Van Allen radiation belts surrounding Earth","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/73/Explorer1.jpg/500px-Explorer1.jpg"},{"n":"Vostok 1","ag":"Soviet Union","ds":"Earth orbit","la":1961,"du":"108 minutes","st":"Success","fa":"Yuri Gagarin became the first human in space, completing one orbit around Earth","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/09/%D0%9A%D0%BE%D1%81%D0%BC%D0%BE%D0%BD%D0%B0%D0%B2%D1%82_%D0%AE%D1%80%D0%B8%D0%B9_%D0%93%D0%B0%D0%B3%D0%B0%D1%80%D0%B8%D0%BD_%28cropped%29.jpg/500px-%D0%9A%D0%BE%D1%81%D0%BC%D0%BE%D0%BD%D0%B0%D0%B2%D1%82_%D0%AE%D1%80%D0%B8%D0%B9_%D0%93%D0%B0%D0%B3%D0%B0%D1%80%D0%B8%D0%BD_%28cropped%29.jpg"},{"n":"Mercury-Atlas 6 (Friendship 7)","ag":"NASA","ds":"Earth orbit","la":1962,"du":"4h 55m","st":"Success","fa":"John Glenn became the first American to orbit Earth, completing three orbits","im":null},{"n":"Voskhod 2","ag":"Soviet Union","ds":"Earth orbit","la":1965,"du":"26 hours","st":"Success","fa":"Alexei Leonov performed the first spacewalk in history, floating in space for 12 minutes","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/19/Zvezda_Rocket_Patch.svg/500px-Zvezda_Rocket_Patch.svg.png"},{"n":"Apollo 8","ag":"NASA","ds":"Moon","la":1968,"du":"6 days","st":"Success","fa":"First crewed mission to orbit the Moon; the iconic Earthrise photograph was taken during this mission","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/NASA-Apollo8-Dec24-Earthrise.jpg/500px-NASA-Apollo8-Dec24-Earthrise.jpg"},{"n":"Apollo 11","ag":"NASA","ds":"Moon","la":1969,"du":"8 days","st":"Success","fa":"Neil Armstrong and Buzz Aldrin became the first humans to walk on the Moon on July 20, 1969","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/41/A_Man_on_the_Moon%2C_AS11-40-5903_%28cropped%29.jpg/500px-A_Man_on_the_Moon%2C_AS11-40-5903_%28cropped%29.jpg"},{"n":"Apollo 13","ag":"NASA","ds":"Moon (aborted)","la":1970,"du":"6 days","st":"Partial","fa":"Oxygen tank explosion forced the crew to use the lunar module as a lifeboat — called a 'successful failure'","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Apollo_13-insignia.png/500px-Apollo_13-insignia.png"},{"n":"Apollo 17","ag":"NASA","ds":"Moon","la":1972,"du":"12 days","st":"Success","fa":"Last crewed Moon landing; astronauts collected a record 110 kg of lunar samples","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Eugene_Cernan_at_the_LM%2C_Apollo_17%2C_AS17-134-20378.jpg/500px-Eugene_Cernan_at_the_LM%2C_Apollo_17%2C_AS17-134-20378.jpg"},{"n":"Luna 9","ag":"Soviet Union","ds":"Moon","la":1966,"du":"3 days","st":"Success","fa":"First spacecraft to achieve a soft landing on the Moon and transmit photos from the lunar surface","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e7/Luna_9_Musee_du_Bourget_P1010505.JPG/500px-Luna_9_Musee_du_Bourget_P1010505.JPG"},{"n":"Luna 16","ag":"Soviet Union","ds":"Moon","la":1970,"du":"11 days","st":"Success","fa":"First robotic mission to collect and return lunar samples to Earth automatically","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bb/Luna_16.jpg/500px-Luna_16.jpg"},{"n":"Mariner 4","ag":"NASA","ds":"Mars","la":1964,"du":"8 months","st":"Success","fa":"First spacecraft to provide close-up images of Mars, revealing a cratered, Moon-like surface","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/Mariner_4_1304_1964novembemariner4.jpg/500px-Mariner_4_1304_1964novembemariner4.jpg"},{"n":"Viking 1","ag":"NASA","ds":"Mars","la":1975,"du":"6 years","st":"Success","fa":"First spacecraft to successfully land on Mars; conducted the first biology experiments on another planet","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/75/Viking_spacecraft.jpg/500px-Viking_spacecraft.jpg"},{"n":"Mars Pathfinder","ag":"NASA","ds":"Mars","la":1996,"du":"83 days","st":"Success","fa":"Delivered Sojourner, the first Mars rover; demonstrated airbag landing system now used by future missions","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7f/Mars_Pathfinder_Lander_preparations.jpg/500px-Mars_Pathfinder_Lander_preparations.jpg"},{"n":"Mars Global Surveyor","ag":"NASA","ds":"Mars","la":1996,"du":"9 years","st":"Success","fa":"Mapped the entire Martian surface and discovered evidence of past water flow and a weak magnetic field","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d8/Mars_global_surveyor.jpg/500px-Mars_global_surveyor.jpg"},{"n":"Spirit","ag":"NASA","ds":"Mars","la":2003,"du":"6 years","st":"Success","fa":"Designed for 90 days, operated for 6 years; discovered silica deposits indicating past presence of water","im":null},{"n":"Opportunity","ag":"NASA","ds":"Mars","la":2003,"du":"15 years","st":"Success","fa":"Designed for 90 days, operated 15 years — the longest-running Mars rover; found clear evidence of ancient water","im":null},{"n":"Mars Reconnaissance Orbiter","ag":"NASA","ds":"Mars","la":2005,"du":"Ongoing","st":"Ongoing","fa":"Highest-resolution Mars camera ever; found evidence of seasonal liquid water flows on Martian slopes","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/58/Mars_Reconnaissance_Orbiter%2C_front_view%2C_artist%27s_concept_%28PIA07245%29.jpg/500px-Mars_Reconnaissance_Orbiter%2C_front_view%2C_artist%27s_concept_%28PIA07245%29.jpg"},{"n":"Phoenix","ag":"NASA","ds":"Mars","la":2007,"du":"5 months","st":"Success","fa":"First mission to directly confirm water ice near the Martian north pole by digging into the soil","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/Phoenix_landing.jpg/960px-Phoenix_landing.jpg"},{"n":"Curiosity","ag":"NASA","ds":"Mars","la":2011,"du":"Ongoing","st":"Ongoing","fa":"Still operational after 13+ years; confirmed Mars once had conditions suitable for microbial life","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/Curiosity_Self-Portrait_at_%27Big_Sky%27_Drilling_Site.jpg/500px-Curiosity_Self-Portrait_at_%27Big_Sky%27_Drilling_Site.jpg"},{"n":"MAVEN","ag":"NASA","ds":"Mars","la":2013,"du":"Ongoing","st":"Ongoing","fa":"Revealed that solar wind stripped away Mars's ancient atmosphere, explaining how it lost its oceans","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/70/MAVEN_Mission_Logo.png/500px-MAVEN_Mission_Logo.png"},{"n":"InSight","ag":"NASA","ds":"Mars","la":2018,"du":"4 years","st":"Success","fa":"Detected over 1,300 marsquakes and measured Mars's internal structure for the first time","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3d/PIA19664-MarsInSightLander-Assembly-20150430.jpg/500px-PIA19664-MarsInSightLander-Assembly-20150430.jpg"},{"n":"Perseverance","ag":"NASA","ds":"Mars","la":2020,"du":"Ongoing","st":"Ongoing","fa":"Collected rock samples for future Earth return; deployed Ingenuity helicopter — first powered flight on another planet","im":null},{"n":"Mars Climate Orbiter","ag":"NASA","ds":"Mars","la":1998,"du":"9 months","st":"Failure","fa":"Lost due to a metric/imperial unit mismatch between teams — one of the most embarrassing NASA failures","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/19/Mars_Climate_Orbiter_2.jpg/500px-Mars_Climate_Orbiter_2.jpg"},{"n":"Venera 7","ag":"Soviet Union","ds":"Venus","la":1970,"du":"35 minutes","st":"Success","fa":"First spacecraft to successfully land on another planet and transmit data from the surface of Venus","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ca/Venera-7_spuskaemiy_apparat.jpg/500px-Venera-7_spuskaemiy_apparat.jpg"},{"n":"Magellan","ag":"NASA","ds":"Venus","la":1989,"du":"4 years","st":"Success","fa":"Mapped 98% of Venus's surface using radar, revealing thousands of volcanoes and lava plains","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1e/Magellan_at_Kennedy_Space_Center.jpg/500px-Magellan_at_Kennedy_Space_Center.jpg"},{"n":"Mariner 10","ag":"NASA","ds":"Mercury & Venus","la":1973,"du":"1 year","st":"Success","fa":"First spacecraft to visit two planets in one mission; photographed 45% of Mercury's surface","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2e/NASM-A19830006000-NASM2019-01579.jpg/500px-NASM-A19830006000-NASM2019-01579.jpg"},{"n":"MESSENGER","ag":"NASA","ds":"Mercury","la":2004,"du":"11 years","st":"Success","fa":"First spacecraft to orbit Mercury; found water ice in permanently shadowed polar craters","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6c/MESSENGER_-_spacecraft_at_mercury_-_atmercury_lg.jpg/500px-MESSENGER_-_spacecraft_at_mercury_-_atmercury_lg.jpg"},{"n":"Parker Solar Probe","ag":"NASA","ds":"Sun","la":2018,"du":"Ongoing","st":"Ongoing","fa":"The fastest human-made object ever (692,000 km/h); has flown through the Sun's corona","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e1/Parker_Solar_Probe_spacecraft_model.png/500px-Parker_Solar_Probe_spacecraft_model.png"},{"n":"SOHO","ag":"ESA/NASA","ds":"Sun","la":1995,"du":"Ongoing","st":"Ongoing","fa":"Has been observing the Sun for 30 years; discovered over 4,000 comets as a side mission","im":null},{"n":"Voyager 1","ag":"NASA","ds":"Interstellar space","la":1977,"du":"Ongoing","st":"Ongoing","fa":"The farthest human-made object from Earth; first to enter interstellar space in 2012, still transmitting","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/60/Voyager_spacecraft_model.png/500px-Voyager_spacecraft_model.png"},{"n":"Voyager 2","ag":"NASA","ds":"Interstellar space","la":1977,"du":"Ongoing","st":"Ongoing","fa":"Only spacecraft to fly past all four outer planets; still operational in interstellar space","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/60/Voyager_spacecraft_model.png/500px-Voyager_spacecraft_model.png"},{"n":"Pioneer 10","ag":"NASA","ds":"Jupiter / beyond","la":1972,"du":"31 years","st":"Success","fa":"First spacecraft to pass through the asteroid belt and fly by Jupiter; carried the Pioneer plaque","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f0/An_artist%27s_impression_of_a_Pioneer_spacecraft_on_its_way_to_interstellar_space.jpg/500px-An_artist%27s_impression_of_a_Pioneer_spacecraft_on_its_way_to_interstellar_space.jpg"},{"n":"Galileo","ag":"NASA","ds":"Jupiter","la":1989,"du":"14 years","st":"Success","fa":"Discovered strong evidence for a liquid water ocean beneath Europa's icy crust","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9c/Artwork_Galileo-Io-Jupiter.JPG/500px-Artwork_Galileo-Io-Jupiter.JPG"},{"n":"Cassini-Huygens","ag":"NASA/ESA","ds":"Saturn","la":1997,"du":"20 years","st":"Success","fa":"13 years orbiting Saturn; Huygens probe landed on Titan, discovering methane lakes and hydrocarbon rain","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b2/Cassini_Saturn_Orbit_Insertion.jpg/500px-Cassini_Saturn_Orbit_Insertion.jpg"},{"n":"Juno","ag":"NASA","ds":"Jupiter","la":2011,"du":"Ongoing","st":"Ongoing","fa":"Orbiting Jupiter's poles, revealing its complex atmospheric structure and massive polar cyclones","im":null},{"n":"New Horizons","ag":"NASA","ds":"Pluto / Kuiper Belt","la":2006,"du":"Ongoing","st":"Ongoing","fa":"First mission to fly by Pluto (2015), revealing a heart-shaped glacier and complex geology","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/New_Horizons_spacecraft_model_1.png/500px-New_Horizons_spacecraft_model_1.png"},{"n":"Huygens probe","ag":"ESA","ds":"Titan (Saturn moon)","la":1997,"du":"72 minutes on surface","st":"Success","fa":"First landing in the outer solar system; transmitted images of a methane lake shoreline on Titan","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/23/Huygens_probe_model.jpg/500px-Huygens_probe_model.jpg"},{"n":"Rosetta / Philae","ag":"ESA","ds":"Comet 67P","la":2004,"du":"12 years","st":"Success","fa":"First mission to orbit a comet; Philae lander became the first to land on a comet nucleus in 2014","im":null},{"n":"Deep Impact","ag":"NASA","ds":"Comet Tempel 1","la":2005,"du":"6 months","st":"Success","fa":"Deliberately crashed an impactor into a comet to study its composition — caused a huge explosion","im":null},{"n":"Hayabusa","ag":"JAXA","ds":"Asteroid Itokawa","la":2003,"du":"7 years","st":"Partial","fa":"First mission to return samples from an asteroid; suffered multiple failures but still returned 1,500 grains","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/Hayabusa_hover.jpg/500px-Hayabusa_hover.jpg"},{"n":"Hayabusa2","ag":"JAXA","ds":"Asteroid Ryugu","la":2014,"du":"6 years","st":"Success","fa":"Collected samples from beneath Ryugu's surface and returned them to Earth in 2020","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/Hayabusa2_Ion_thruster.jpg/500px-Hayabusa2_Ion_thruster.jpg"},{"n":"OSIRIS-REx","ag":"NASA","ds":"Asteroid Bennu","la":2016,"du":"Ongoing","st":"Success","fa":"Collected a record 250g sample from asteroid Bennu and returned it to Earth in 2023","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7b/OSIRIS-REx_spacecraft_model.png/500px-OSIRIS-REx_spacecraft_model.png"},{"n":"DART","ag":"NASA","ds":"Asteroid Dimorphos","la":2021,"du":"10 months","st":"Success","fa":"First planetary defense mission; deliberately crashed into Dimorphos and successfully changed its orbit","im":null},{"n":"Hubble Space Telescope","ag":"NASA/ESA","ds":"Earth orbit","la":1990,"du":"Ongoing","st":"Ongoing","fa":"Revolutionized astronomy over 35 years; determined the universe's expansion rate and age (~13.8 billion years)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8e/STS-109-HST-s109e5700.jpg/500px-STS-109-HST-s109e5700.jpg"},{"n":"James Webb Space Telescope","ag":"NASA/ESA/CSA","ds":"L2 point","la":2021,"du":"Ongoing","st":"Ongoing","fa":"Most powerful space telescope ever built; can observe the first galaxies formed after the Big Bang","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/JWST_spacecraft_model_3.png/500px-JWST_spacecraft_model_3.png"},{"n":"Kepler Space Telescope","ag":"NASA","ds":"Earth-trailing orbit","la":2009,"du":"9 years","st":"Success","fa":"Discovered over 2,600 confirmed exoplanets, revolutionizing our understanding of planetary systems","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/45/Kepler_Space_Telescope_spacecraft_model_2.png/500px-Kepler_Space_Telescope_spacecraft_model_2.png"},{"n":"Spitzer Space Telescope","ag":"NASA","ds":"Earth-trailing orbit","la":2003,"du":"16 years","st":"Success","fa":"Infrared telescope that revealed the first light spectrum of exoplanet atmospheres","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Spitzer_space_telescope.jpg/500px-Spitzer_space_telescope.jpg"},{"n":"Chandra X-ray Observatory","ag":"NASA","ds":"Earth orbit","la":1999,"du":"Ongoing","st":"Ongoing","fa":"Observes X-rays from black holes, neutron stars and supernova remnants invisible to optical telescopes","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fd/Chandra_artist_illustration.jpg/500px-Chandra_artist_illustration.jpg"},{"n":"TESS","ag":"NASA","ds":"HEO orbit","la":2018,"du":"Ongoing","st":"Ongoing","fa":"Searching the entire sky for exoplanets orbiting nearby bright stars; found over 5,000 candidates","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/4d/TESS_alone_high_res.jpg/500px-TESS_alone_high_res.jpg"},{"n":"Mir","ag":"Soviet Union / Russia","ds":"Earth orbit","la":1986,"du":"15 years","st":"Success","fa":"First modular space station; hosted international cosmonauts and proved long-duration human spaceflight","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/09/Mir_Space_Station_viewed_from_Endeavour_during_STS-89.jpg/500px-Mir_Space_Station_viewed_from_Endeavour_during_STS-89.jpg"},{"n":"International Space Station","ag":"NASA/Roscosmos/ESA/JAXA/CSA","ds":"Earth orbit","la":1998,"du":"Ongoing","st":"Ongoing","fa":"Largest structure ever assembled in space; continuously inhabited since November 2000 by 270+ astronauts","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/The_station_pictured_from_the_SpaceX_Crew_Dragon_5.jpg/500px-The_station_pictured_from_the_SpaceX_Crew_Dragon_5.jpg"},{"n":"Tiangong-3","ag":"CNSA","ds":"Earth orbit","la":2021,"du":"Ongoing","st":"Ongoing","fa":"China's permanent space station; completed and operational by 2022 as China's independent orbital outpost","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/25/Chinese_Tiangong_Space_Station.jpg/500px-Chinese_Tiangong_Space_Station.jpg"},{"n":"SpaceX Crew Dragon Demo-2","ag":"NASA/SpaceX","ds":"ISS","la":2020,"du":"64 days","st":"Success","fa":"First crewed commercial spacecraft to reach the ISS; ended US dependence on Russian Soyuz for astronaut transport","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/dd/SpaceX_Demo-2_Launch_%28NHQ202005300044%29.jpg/500px-SpaceX_Demo-2_Launch_%28NHQ202005300044%29.jpg"},{"n":"Artemis I","ag":"NASA","ds":"Moon","la":2022,"du":"25 days","st":"Success","fa":"First uncrewed test of the Orion capsule around the Moon, paving the way for the return of humans to the Moon","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/66/Orion_Approaches_Moon_for_Outbound_Powered_Flyby.jpg/500px-Orion_Approaches_Moon_for_Outbound_Powered_Flyby.jpg"},{"n":"JWST First Images","ag":"NASA/ESA/CSA","ds":"L2 point","la":2022,"du":"Ongoing","st":"Ongoing","fa":"Released the deepest infrared image of the universe ever taken — showing galaxies formed 13 billion years ago","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/JWST_spacecraft_model_3.png/500px-JWST_spacecraft_model_3.png"},{"n":"Chandrayaan-3","ag":"ISRO","ds":"Moon south pole","la":2023,"du":"14 days","st":"Success","fa":"India became the first country to land near the lunar south pole and 4th nation to land on the Moon","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/Chandrayaan-3_%E2%80%93_Image_of_Vikram_lander_on_lunar_surface_taken_by_Pragyan_rover_navcam_at_1104_IST%2C_30_August_2023_from_15_meters_away_%28with_text%29.webp/500px-Chandrayaan-3_%E2%80%93_Image_of_Vikram_lander_on_lunar_surface_taken_by_Pragyan_rover_navcam_at_1104_IST%2C_30_August_2023_from_15_meters_away_%28with_text%29.webp.png"},{"n":"BepiColombo","ag":"ESA/JAXA","ds":"Mercury","la":2018,"du":"Ongoing","st":"Ongoing","fa":"Joint ESA-JAXA mission to Mercury using gravity assists from Venus and Mercury; arrival expected 2025","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d4/BepiColombo_spacecraft_model.png/500px-BepiColombo_spacecraft_model.png"},{"n":"Europa Clipper","ag":"NASA","ds":"Jupiter / Europa","la":2024,"du":"Ongoing","st":"Ongoing","fa":"Will perform 49 close flybys of Europa to assess whether its subsurface ocean could support life","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/59/Europa_Clipper_spacecraft_model.png/500px-Europa_Clipper_spacecraft_model.png"},{"n":"Dragonfly","ag":"NASA","ds":"Titan","la":2028,"du":"Planned","st":"Ongoing","fa":"Rotorcraft lander that will fly to dozens of sites on Titan to search for chemical life signatures","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3a/Dragonfly-landing.png/500px-Dragonfly-landing.png"},{"n":"Lunar Gateway","ag":"NASA/ESA/JAXA/CSA","ds":"Moon orbit","la":2025,"du":"Planned","st":"Ongoing","fa":"First permanent space station in lunar orbit; will serve as staging point for Moon and Mars missions","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Lunar_Gateway_rendering_2.webp/500px-Lunar_Gateway_rendering_2.webp.png"},{"n":"Challenger STS-51-L","ag":"NASA","ds":"Earth orbit","la":1986,"du":"73 seconds","st":"Failure","fa":"Broke apart 73 seconds after launch due to O-ring failure; all 7 crew members were lost","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9f/Challenger_explosion.jpg/500px-Challenger_explosion.jpg"},{"n":"Columbia STS-107","ag":"NASA","ds":"Earth orbit","la":2003,"du":"16 days","st":"Failure","fa":"Disintegrated on re-entry due to foam damage on the wing; all 7 astronauts were lost","im":"https://upload.wikimedia.org/wikipedia/commons/4/48/ColumbiaFLIR2003.gif"},{"n":"Mars Polar Lander","ag":"NASA","ds":"Mars","la":1999,"du":"N/A","st":"Failure","fa":"Contact lost during landing; a software error likely caused premature engine shutdown before touchdown","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/96/Mars_Polar_Lander_-_artist_depiction.png/500px-Mars_Polar_Lander_-_artist_depiction.png"}]