[{"n":"Tyrannosaurus rex","pe":"Late Cretaceous (68-66 Ma)","di":"Carnivore","le":12.0,"we":8000,"yr":1902,"dc":"Henry Fairfield Osborn","fa":"One of the largest land predators ever, with the most powerful bite force of any terrestrial animal","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/94/Tyrannosaurus_Rex_Holotype.jpg/500px-Tyrannosaurus_Rex_Holotype.jpg"},{"n":"Spinosaurus","pe":"Late Cretaceous (99-93 Ma)","di":"Piscivore","le":14.0,"we":7400,"yr":1915,"dc":"Ernst Stromer","fa":"Longest carnivorous dinosaur known, semi-aquatic and a specialist fish hunter in North Africa","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f0/FSAC-KK-11888.jpg/500px-FSAC-KK-11888.jpg"},{"n":"Giganotosaurus","pe":"Late Cretaceous (99-97 Ma)","di":"Carnivore","le":12.5,"we":6800,"yr":1995,"dc":"Coria & Salgado","fa":"One of the largest meat-eating dinosaurs, rivalling T. rex in size, from Patagonia, Argentina","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/af/Giganotosaurus_at_Fernbank.jpg/500px-Giganotosaurus_at_Fernbank.jpg"},{"n":"Carcharodontosaurus","pe":"Late Cretaceous (99-94 Ma)","di":"Carnivore","le":12.0,"we":6000,"yr":1925,"dc":"Ernst Stromer","fa":"Named for its shark-like teeth, one of the apex predators of North Africa alongside Spinosaurus","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/13/Ultimate_Dinosaurs_Carcharodontosaurus.jpg/500px-Ultimate_Dinosaurs_Carcharodontosaurus.jpg"},{"n":"Carnotaurus","pe":"Late Cretaceous (72-69 Ma)","di":"Carnivore","le":8.5,"we":1500,"yr":1985,"dc":"José Bonaparte","fa":"Unique among theropods for its two horn-like crests above its eyes and extremely short arms","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cc/Carnotaurus%2C_Chlup%C3%A1%C4%8D_Museum%2C_Prague-2.jpg/500px-Carnotaurus%2C_Chlup%C3%A1%C4%8D_Museum%2C_Prague-2.jpg"},{"n":"Velociraptor","pe":"Late Cretaceous (75-71 Ma)","di":"Carnivore","le":2.0,"we":15,"yr":1923,"dc":"Henry Fairfield Osborn","fa":"A feathered pack hunter with a lethal retractable claw; far smaller than its Jurassic Park depiction","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3d/Velociraptor_skeleton_white_background.jpg/500px-Velociraptor_skeleton_white_background.jpg"},{"n":"Deinonychus","pe":"Early Cretaceous (115-108 Ma)","di":"Carnivore","le":3.4,"we":73,"yr":1969,"dc":"John Ostrom","fa":"Its discovery revolutionized paleontology by proving dinosaurs were active, warm-blooded animals","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/98/Deinonychus_FMNH.jpg/500px-Deinonychus_FMNH.jpg"},{"n":"Utahraptor","pe":"Early Cretaceous (126-125 Ma)","di":"Carnivore","le":6.0,"we":500,"yr":1993,"dc":"James Kirkland","fa":"The largest known dromaeosaurid, with a sickle claw 24 cm long — the real-size 'Jurassic Park raptor'","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/69/BYU_Utahraptor_skeletal_mount.jpg/500px-BYU_Utahraptor_skeletal_mount.jpg"},{"n":"Troodon","pe":"Late Cretaceous (77-66 Ma)","di":"Omnivore","le":2.4,"we":50,"yr":1856,"dc":"Joseph Leidy","fa":"Had the largest brain-to-body ratio of any known dinosaur, possibly comparable to modern birds","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/Troodon_MOR_full.png/500px-Troodon_MOR_full.png"},{"n":"Baryonyx","pe":"Early Cretaceous (130-125 Ma)","di":"Piscivore","le":8.5,"we":2000,"yr":1986,"dc":"Charig & Milner","fa":"Found with fish scales in its stomach — the first direct evidence of piscivory in a large theropod","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1a/Baryonyx_walkeri_mount_NMNS.jpg/500px-Baryonyx_walkeri_mount_NMNS.jpg"},{"n":"Oviraptor","pe":"Late Cretaceous (75-71 Ma)","di":"Omnivore","le":1.8,"we":35,"yr":1924,"dc":"Henry Fairfield Osborn","fa":"Falsely accused of egg theft for 70 years; the eggs it was found with were actually its own","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/32/Oviraptor_holotype.jpg/500px-Oviraptor_holotype.jpg"},{"n":"Therizinosaurus","pe":"Late Cretaceous (70-68 Ma)","di":"Herbivore","le":10.0,"we":5000,"yr":1954,"dc":"Maleev","fa":"Had the longest claws of any known animal — up to 1 metre — despite being a plant eater","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cd/Therizinosaurus_arms.jpg/500px-Therizinosaurus_arms.jpg"},{"n":"Dilophosaurus","pe":"Early Jurassic (196-183 Ma)","di":"Carnivore","le":6.0,"we":400,"yr":1954,"dc":"Samuel Welles","fa":"First large theropod of the Jurassic; the twin cranial crests likely served for display or species recognition","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/12/DilophosaurusROM1.JPG/500px-DilophosaurusROM1.JPG"},{"n":"Microraptor","pe":"Early Cretaceous (125-120 Ma)","di":"Carnivore","le":0.9,"we":1,"yr":2000,"dc":"Xu Xing","fa":"Had four wings — one pair on its arms and one on its legs — and could likely glide between trees","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/af/Microraptor_gui_holotype.png/500px-Microraptor_gui_holotype.png"},{"n":"Triceratops","pe":"Late Cretaceous (68-66 Ma)","di":"Herbivore","le":9.0,"we":12000,"yr":1889,"dc":"Othniel Charles Marsh","fa":"Its three horns and massive frill made it one of the most iconic herbivores; it co-existed with T. rex","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/LA-Triceratops_mount-2.jpg/500px-LA-Triceratops_mount-2.jpg"},{"n":"Ankylosaurus","pe":"Late Cretaceous (68-66 Ma)","di":"Herbivore","le":9.0,"we":6000,"yr":1908,"dc":"Barnum Brown","fa":"Walking fortress: armoured from head to tail with a bone-shattering club at the end of its tail","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f0/Ankylosaur_head_-_cast_-_Custer_County_Montana_-_Museum_of_the_Rockies_-_2013-07-08.jpg/500px-Ankylosaur_head_-_cast_-_Custer_County_Montana_-_Museum_of_the_Rockies_-_2013-07-08.jpg"},{"n":"Parasaurolophus","pe":"Late Cretaceous (76-73 Ma)","di":"Herbivore","le":10.0,"we":2500,"yr":1922,"dc":"William Arthur Parks","fa":"Its hollow tube-like crest could amplify sound to communicate across long distances through forests","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f2/FMNH_Parasaurolophus_fossil.jpg/500px-FMNH_Parasaurolophus_fossil.jpg"},{"n":"Pachycephalosaurus","pe":"Late Cretaceous (70-66 Ma)","di":"Herbivore","le":4.5,"we":450,"yr":1943,"dc":"Brown & Schlaikjer","fa":"Its skull dome was up to 25 cm thick — possibly used for head-butting rivals during mating season","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c1/Pachycephalosaurus_wyomingensis_ROM.jpg/500px-Pachycephalosaurus_wyomingensis_ROM.jpg"},{"n":"Maiasaura","pe":"Late Cretaceous (76-75 Ma)","di":"Herbivore","le":9.0,"we":4000,"yr":1979,"dc":"Horner & Makela","fa":"First dinosaur proven to care for its young in nests — its name means 'good mother lizard'","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/Maiasaura_skeleton.jpg/500px-Maiasaura_skeleton.jpg"},{"n":"Styracosaurus","pe":"Late Cretaceous (75-74 Ma)","di":"Herbivore","le":5.5,"we":2700,"yr":1913,"dc":"Lawrence Lambe","fa":"Its spectacular frill bore six long spikes; one of the most ornate skull arrangements in the dinosaur world","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/dc/StyracosaurCMN2.jpg/500px-StyracosaurCMN2.jpg"},{"n":"Edmontosaurus","pe":"Late Cretaceous (73-66 Ma)","di":"Herbivore","le":13.0,"we":4000,"yr":1917,"dc":"Lawrence Lambe","fa":"One of the largest hadrosaurs, found with mummified skin preserving scale impressions and tissue","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d7/Edmontosaurus_Family_Clean.png/500px-Edmontosaurus_Family_Clean.png"},{"n":"Protoceratops","pe":"Late Cretaceous (75-71 Ma)","di":"Herbivore","le":1.8,"we":180,"yr":1923,"dc":"Granger & Gregory","fa":"Found in the Gobi Desert — including the famous 'Fighting Dinosaurs' fossil locked in combat with Velociraptor","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Andrewsi.jpg/500px-Andrewsi.jpg"},{"n":"Psittacosaurus","pe":"Early Cretaceous (126-101 Ma)","di":"Herbivore","le":2.0,"we":20,"yr":1923,"dc":"Henry Fairfield Osborn","fa":"Most species-rich dinosaur genus with 11 species; fossils show quill-like structures on its tail","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/85/The_Childrens_Museum_of_Indianapolis_-_Psittacosaurus_skeleton_cast.jpg/500px-The_Childrens_Museum_of_Indianapolis_-_Psittacosaurus_skeleton_cast.jpg"},{"n":"Iguanodon","pe":"Early Cretaceous (140-110 Ma)","di":"Herbivore","le":10.0,"we":3000,"yr":1825,"dc":"Gideon Mantell","fa":"Second dinosaur ever named; its thumb spike was initially mistaken for a horn on its nose","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/70/Iguanodon_de_Bernissart_IRSNB_01.JPG/500px-Iguanodon_de_Bernissart_IRSNB_01.JPG"},{"n":"Allosaurus","pe":"Late Jurassic (155-145 Ma)","di":"Carnivore","le":9.5,"we":2000,"yr":1877,"dc":"Othniel Charles Marsh","fa":"Apex predator of the Late Jurassic, hunting sauropods; may have hunted in packs like modern wolves","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/56/WLA_hmns_Allosaurus_White_Background.jpg/500px-WLA_hmns_Allosaurus_White_Background.jpg"},{"n":"Ceratosaurus","pe":"Late Jurassic (153-148 Ma)","di":"Carnivore","le":7.0,"we":700,"yr":1884,"dc":"Othniel Charles Marsh","fa":"Had a prominent horn on its nose and bony ridges above each eye — unique among Jurassic theropods","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/77/Ceratosaurus_mount_utah_museum_1.jpg/500px-Ceratosaurus_mount_utah_museum_1.jpg"},{"n":"Megalosaurus","pe":"Middle Jurassic (166-164 Ma)","di":"Carnivore","le":6.0,"we":700,"yr":1824,"dc":"William Buckland","fa":"First dinosaur ever formally named and described, in England in 1824 — the beginning of dinosaur science","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Megalosaurus_display.JPG/500px-Megalosaurus_display.JPG"},{"n":"Compsognathus","pe":"Late Jurassic (150-148 Ma)","di":"Carnivore","le":1.0,"we":2.5,"yr":1859,"dc":"Johann Wagner","fa":"Long thought to be the smallest dinosaur, about the size of a chicken; found with a lizard in its stomach","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/49/Compy.jpg/500px-Compy.jpg"},{"n":"Ornitholestes","pe":"Late Jurassic (154-153 Ma)","di":"Carnivore","le":2.0,"we":12,"yr":1903,"dc":"Henry Fairfield Osborn","fa":"Small agile predator thought to have hunted early birds and lizards in the forests of the Jurassic","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ea/Ornitholestes_Royal_Tyrrell_2.jpg/500px-Ornitholestes_Royal_Tyrrell_2.jpg"},{"n":"Brachiosaurus","pe":"Late Jurassic (154-153 Ma)","di":"Herbivore","le":26.0,"we":56000,"yr":1903,"dc":"Elmer Riggs","fa":"One of the tallest dinosaurs with front legs longer than its back legs, reaching 13 metres in height","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ed/Brachiosaurus_mount.jpg/500px-Brachiosaurus_mount.jpg"},{"n":"Brontosaurus","pe":"Late Jurassic (156-151 Ma)","di":"Herbivore","le":22.0,"we":17000,"yr":1879,"dc":"Othniel Charles Marsh","fa":"Declared invalid for 112 years before being re-validated as a distinct genus in 2015","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/74/Brontosaurus_excelsus_remount_in_the_Peabody_Museum.jpg/500px-Brontosaurus_excelsus_remount_in_the_Peabody_Museum.jpg"},{"n":"Diplodocus","pe":"Late Jurassic (154-152 Ma)","di":"Herbivore","le":27.0,"we":14000,"yr":1878,"dc":"Othniel Charles Marsh","fa":"One of the longest dinosaurs known; it likely used its whip-like tail to produce a supersonic crack","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/df/CM_Diplodocus.jpg/500px-CM_Diplodocus.jpg"},{"n":"Stegosaurus","pe":"Late Jurassic (155-150 Ma)","di":"Herbivore","le":9.0,"we":5000,"yr":1877,"dc":"Othniel Charles Marsh","fa":"The iconic double row of plates on its back may have been used for thermoregulation or display","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bc/Journal.pone.0138352.g001A.jpg/500px-Journal.pone.0138352.g001A.jpg"},{"n":"Apatosaurus","pe":"Late Jurassic (152-151 Ma)","di":"Herbivore","le":21.0,"we":20000,"yr":1877,"dc":"Othniel Charles Marsh","fa":"Confused with Brontosaurus for a century; one of the most massive animals ever to walk on land","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c4/Apatosaurus_louisae_-_CM.jpg/500px-Apatosaurus_louisae_-_CM.jpg"},{"n":"Camarasaurus","pe":"Late Jurassic (155-145 Ma)","di":"Herbivore","le":18.0,"we":18000,"yr":1877,"dc":"Edward Drinker Cope","fa":"Most common sauropod of the Morrison Formation; its large nasal openings suggest a keen sense of smell","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/33/Camarasaurus_lentus_Carnegie.jpg/500px-Camarasaurus_lentus_Carnegie.jpg"},{"n":"Camptosaurus","pe":"Late Jurassic (155-145 Ma)","di":"Herbivore","le":7.9,"we":874,"yr":1879,"dc":"Othniel Charles Marsh","fa":"Could walk on two or four legs and was likely a key prey animal for Allosaurus","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Camptosaurus_dispar_skeleton.jpg/500px-Camptosaurus_dispar_skeleton.jpg"},{"n":"Eoraptor","pe":"Late Triassic (231 Ma)","di":"Omnivore","le":1.0,"we":10,"yr":1993,"dc":"Paul Sereno","fa":"One of the earliest known dinosaurs, found in Argentina — a small window into the very origin of the group","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/89/Eoraptor_Lunensis_20250105.jpg/500px-Eoraptor_Lunensis_20250105.jpg"},{"n":"Herrerasaurus","pe":"Late Triassic (235-228 Ma)","di":"Carnivore","le":6.0,"we":350,"yr":1963,"dc":"Osvaldo Reig","fa":"Among the earliest true dinosaurs; its anatomy shows the rapid diversification at the dawn of the group","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/13/Herrerasaurus_skeleton.jpg/500px-Herrerasaurus_skeleton.jpg"},{"n":"Plateosaurus","pe":"Late Triassic (214-204 Ma)","di":"Herbivore","le":10.0,"we":4000,"yr":1837,"dc":"Hermann von Meyer","fa":"One of the first large dinosaurs; found in great numbers across Europe suggesting herd behaviour","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/93/Plateosaurus_Skelett_2.jpg/500px-Plateosaurus_Skelett_2.jpg"},{"n":"Coelophysis","pe":"Late Triassic (213-203 Ma)","di":"Carnivore","le":3.0,"we":20,"yr":1889,"dc":"Edward Drinker Cope","fa":"Found in mass graves of hundreds of individuals at Ghost Ranch, New Mexico — evidence of herding","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/57/Coelophysis_bauri_mount.jpg/500px-Coelophysis_bauri_mount.jpg"},{"n":"Argentinosaurus","pe":"Late Cretaceous (96-92 Ma)","di":"Herbivore","le":35.0,"we":70000,"yr":1993,"dc":"Bonaparte & Coria","fa":"Possibly the heaviest land animal ever known, weighing up to 70 tonnes — heavier than 10 African elephants","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/06/Argentinosaurus_skeleton%2C_PLoS_ONE.png/500px-Argentinosaurus_skeleton%2C_PLoS_ONE.png"},{"n":"Patagotitan","pe":"Late Cretaceous (101-98 Ma)","di":"Herbivore","le":37.0,"we":69000,"yr":2014,"dc":"Carballido et al.","fa":"The largest dinosaur whose size has been scientifically confirmed — its femur alone is 2.4 metres long","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/45/FMNH_Patagotitan.jpg/500px-FMNH_Patagotitan.jpg"},{"n":"Quetzalcoatlus","pe":"Late Cretaceous (68-66 Ma)","di":"Carnivore","le":null,"we":250,"yr":1971,"dc":"Douglas Lawson","fa":"The largest flying animal ever known with a wingspan up to 11 metres — the size of a small aircraft","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/27/Quetzalcoatlus_northropi.jpg/500px-Quetzalcoatlus_northropi.jpg"},{"n":"Spinosaurus aegyptiacus","pe":"Late Cretaceous (99-93 Ma)","di":"Piscivore","le":15.0,"we":7500,"yr":1915,"dc":"Ernst Stromer","fa":"Recent discoveries show it was primarily aquatic with dense bones for buoyancy control, unlike any other theropod","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f0/FSAC-KK-11888.jpg/500px-FSAC-KK-11888.jpg"},{"n":"Archaeopteryx","pe":"Late Jurassic (150-148 Ma)","di":"Carnivore","le":0.5,"we":1,"yr":1861,"dc":"Christian Erich Hermann von Meyer","fa":"The missing link between dinosaurs and birds — it had feathers and wings but also teeth and a bony tail","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Archaeopteryx_lithographica_%28Berlin_specimen%29.jpg/500px-Archaeopteryx_lithographica_%28Berlin_specimen%29.jpg"},{"n":"Dimetrodon","pe":"Early Permian (295-272 Ma)","di":"Carnivore","le":3.0,"we":250,"yr":1878,"dc":"Edward Drinker Cope","fa":"Often mistaken for a dinosaur but actually predated them by 40 million years — closer to mammals","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Dimetrodon_incisivum_01.jpg/500px-Dimetrodon_incisivum_01.jpg"},{"n":"Irritator","pe":"Early Cretaceous (110 Ma)","di":"Piscivore","le":8.0,"we":1000,"yr":1996,"dc":"Martill et al.","fa":"Named after the irritation felt by scientists when they discovered the skull had been fraudulently altered by dealers","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c0/Irritator_challengeri_mount_01.jpg/500px-Irritator_challengeri_mount_01.jpg"},{"n":"Dracorex hogwartsia","pe":"Late Cretaceous (66 Ma)","di":"Herbivore","le":3.0,"we":200,"yr":2006,"dc":"Robert Bakker","fa":"Named after Hogwarts from Harry Potter; its dragon-like skull with spikes inspired the school's name","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c1/Pachycephalosaurus_wyomingensis_ROM.jpg/500px-Pachycephalosaurus_wyomingensis_ROM.jpg"},{"n":"Buitreraptor","pe":"Late Cretaceous (90 Ma)","di":"Carnivore","le":1.5,"we":3,"yr":2005,"dc":"Makovicky et al.","fa":"Proves dromaeosaurids originated in Gondwana and later spread north, reversing the assumed migration","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0f/BuitreraptorROM.JPG/500px-BuitreraptorROM.JPG"},{"n":"Nodosaurus","pe":"Early Cretaceous (110-100 Ma)","di":"Herbivore","le":6.0,"we":1900,"yr":1889,"dc":"Othniel Charles Marsh","fa":"First ankylosaur ever discovered; its armour consisted of nodes and plates embedded directly in its skin","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7e/The_American_journal_of_science_%281921%29_%2817529968373%29.jpg/500px-The_American_journal_of_science_%281921%29_%2817529968373%29.jpg"},{"n":"Sauropelta","pe":"Early Cretaceous (130-112 Ma)","di":"Herbivore","le":5.0,"we":1500,"yr":1970,"dc":"John Ostrom","fa":"Had large shoulder spikes that may have been used for defence against predators like Deinonychus","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/97/Sauropelta.jpg/500px-Sauropelta.jpg"},{"n":"Gallimimus","pe":"Late Cretaceous (70 Ma)","di":"Omnivore","le":6.0,"we":440,"yr":1972,"dc":"Osmolska et al.","fa":"One of the fastest dinosaurs, estimated at up to 50 km/h, resembling a large modern ostrich in build","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/51/Gallimimus_bullatus.001_-_Natural_History_Museum_of_London.JPG/500px-Gallimimus_bullatus.001_-_Natural_History_Museum_of_London.JPG"},{"n":"Pachyrhinosaurus","pe":"Late Cretaceous (73-69 Ma)","di":"Herbivore","le":8.0,"we":4000,"yr":1950,"dc":"Charles Sternberg","fa":"Had a thick bony mass on its nose instead of a horn — the function is still debated by palaeontologists","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/Pachyrhinosaurus_Royal_Tyrrell_1.jpg/500px-Pachyrhinosaurus_Royal_Tyrrell_1.jpg"},{"n":"Corythosaurus","pe":"Late Cretaceous (77-75 Ma)","di":"Herbivore","le":9.0,"we":4000,"yr":1914,"dc":"Barnum Brown","fa":"Its hollow helmet-shaped crest was used as a resonating chamber to produce loud calls to attract mates","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2d/Carnegie_Corythosaurus.jpg/500px-Carnegie_Corythosaurus.jpg"},{"n":"Lambeosaurus","pe":"Late Cretaceous (76-75 Ma)","di":"Herbivore","le":15.0,"we":5600,"yr":1923,"dc":"William Arthur Parks","fa":"Had a distinctive hatchet-shaped crest; the largest known hadrosaur, exceeding T. rex in length","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/20/Lambeosaurus_Pacific_Museum_of_Earth.jpg/500px-Lambeosaurus_Pacific_Museum_of_Earth.jpg"},{"n":"Spinops","pe":"Late Cretaceous (75 Ma)","di":"Herbivore","le":6.0,"we":2000,"yr":2011,"dc":"Farke et al.","fa":"Stored in museum drawers for 100 years before being properly described — a warning about museum collections","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f8/Spinops.jpg/500px-Spinops.jpg"},{"n":"Wuerhosaurus","pe":"Early Cretaceous (132-130 Ma)","di":"Herbivore","le":8.0,"we":4000,"yr":1973,"dc":"Dong Zhiming","fa":"One of the last known stegosaurids — proof that the group survived into the Cretaceous in Asia","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9e/Wuerhosaurus_by_ABelov2014.jpg/500px-Wuerhosaurus_by_ABelov2014.jpg"},{"n":"Yutyrannus","pe":"Early Cretaceous (125 Ma)","di":"Carnivore","le":9.0,"we":1414,"yr":2012,"dc":"Xu Xing et al.","fa":"The largest feathered animal ever known; its discovery confirmed that even large tyrannosaurids had feathers","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Laika_ac_Dino_Kingdom_2012_%287882288828%29.jpg/500px-Laika_ac_Dino_Kingdom_2012_%287882288828%29.jpg"},{"n":"Sinosauropteryx","pe":"Early Cretaceous (124 Ma)","di":"Carnivore","le":1.0,"we":0.5,"yr":1996,"dc":"Ji & Ji","fa":"First non-avian dinosaur found with feathers, also the first whose colour was scientifically determined (rusty orange)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c5/Sinosauropteryxfossil.jpg/500px-Sinosauropteryxfossil.jpg"},{"n":"Tsintaosaurus","pe":"Late Cretaceous (84-71 Ma)","di":"Herbivore","le":10.0,"we":3000,"yr":1958,"dc":"Young","fa":"Had a forward-pointing crest that gave it the nickname 'unicorn dinosaur' — unique in the hadrosaur family","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/01/Tsintaosaurus_nasal.png/500px-Tsintaosaurus_nasal.png"},{"n":"Alxasaurus","pe":"Early Cretaceous (112 Ma)","di":"Herbivore","le":4.0,"we":380,"yr":1993,"dc":"Russell & Dong","fa":"One of the earliest therizinosaurs, confirming that this bizarre group descended from carnivorous ancestors","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Alxasaurus_FukuiJH.jpg/500px-Alxasaurus_FukuiJH.jpg"},{"n":"Magyarosaurus","pe":"Late Cretaceous (70-66 Ma)","di":"Herbivore","le":6.0,"we":900,"yr":1932,"dc":"von Huene","fa":"A dwarf sauropod that evolved on an ancient island — island dwarfism reduced it to the size of a horse","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/61/Titanosaur_remains_used_to_erect_Magyarosaurus_dacus.jpg/500px-Titanosaur_remains_used_to_erect_Magyarosaurus_dacus.jpg"},{"n":"Heterodontosaurus","pe":"Early Jurassic (201-190 Ma)","di":"Omnivore","le":1.2,"we":2.3,"yr":1962,"dc":"Crompton & Charig","fa":"Had three types of teeth — incisors, canines and molars — uniquely varied dentition for any dinosaur","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c2/Heterodontosaurus_tucki_cast_-_University_of_California_Museum_of_Paleontology_-_Berkeley%2C_CA_-_DSC04696.JPG/500px-Heterodontosaurus_tucki_cast_-_University_of_California_Museum_of_Paleontology_-_Berkeley%2C_CA_-_DSC04696.JPG"},{"n":"Amargasaurus","pe":"Early Cretaceous (130-126 Ma)","di":"Herbivore","le":9.0,"we":7000,"yr":1991,"dc":"Bonaparte & Salgado","fa":"Had two rows of tall neural spines along its neck and back, possibly forming a sail or skin-covered crest","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Amargasaurus_in_Prague_National_Museum.jpg/500px-Amargasaurus_in_Prague_National_Museum.jpg"},{"n":"Kosmoceratops","pe":"Late Cretaceous (76 Ma)","di":"Herbivore","le":5.0,"we":1200,"yr":2010,"dc":"Scott Sampson et al.","fa":"Had 15 horns — more than any other 