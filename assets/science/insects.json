[{"n":"Ladybug","ord":"Coleoptera","fam":"Coccinellidae","ha":"Gardens, meadows, forests","di":"Aphids, scale insects","si":"4-8 mm","ff":"A single ladybug can eat up to 5,000 aphids in its lifetime.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2e/Adalia_bipunctata_%282007-04-08%29.jpg/500px-Adalia_bipunctata_%282007-04-08%29.jpg"},{"n":"Stag Beetle","ord":"Coleoptera","fam":"Lucanidae","ha":"Deciduous forests","di":"Tree sap, decaying wood (larvae)","si":"25-75 mm","ff":"Males use their enormous antler-like mandibles to wrestle rivals for mating rights.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1f/Golden_stag_beetle.jpg/500px-Golden_stag_beetle.jpg"},{"n":"Hercules Beetle","ord":"Coleoptera","fam":"Dynastinae","ha":"Tropical rainforests","di":"Decaying wood, fruit","si":"50-170 mm","ff":"One of the world's largest insects; the horn alone can be longer than its body.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/09/Hercules_beetle_%28Dynastes_hercules%29%2C_Entomica.jpg/500px-Hercules_beetle_%28Dynastes_hercules%29%2C_Entomica.jpg"},{"n":"Goliath Beetle","ord":"Coleoptera","fam":"Cetoniinae","ha":"African tropical forests","di":"Tree sap, ripe fruit","si":"50-110 mm","ff":"Among the heaviest insects on Earth, weighing up to 100 g as larvae.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0d/Goliathus_goliatus_dos.jpg/500px-Goliathus_goliatus_dos.jpg"},{"n":"Firefly","ord":"Coleoptera","fam":"Lampyridae","ha":"Meadows, forest edges, wetlands","di":"Nectar, other insects","si":"5-25 mm","ff":"Produces cold light (bioluminescence) with nearly 100% efficiency — no heat is wasted.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/52/Photuris_lucicrescens.jpg/500px-Photuris_lucicrescens.jpg"},{"n":"Bombardier Beetle","ord":"Coleoptera","fam":"Carabidae","ha":"Grasslands, forests","di":"Other insects","si":"10-25 mm","ff":"Fires a boiling chemical spray at 100°C from its abdomen up to 500 times per second.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Brachinus_spPCCA20060328-2821B.jpg/500px-Brachinus_spPCCA20060328-2821B.jpg"},{"n":"Dung Beetle","ord":"Coleoptera","fam":"Scarabaeidae","ha":"Savannas, grasslands, forests","di":"Animal dung","si":"10-30 mm","ff":"Ancient Egyptians worshipped the scarab; dung beetles navigate using the Milky Way.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/43/Dung_beetle_%28Deltochilum_mexicanum%29_3.jpg/500px-Dung_beetle_%28Deltochilum_mexicanum%29_3.jpg"},{"n":"Longhorn Beetle","ord":"Coleoptera","fam":"Cerambycidae","ha":"Forests worldwide","di":"Wood, plant tissue (larvae)","si":"10-60 mm","ff":"Some species have antennae three times the length of their body.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/35/Longhorn_Beetle_Whitespotted_Sawyer_USA.jpg/500px-Longhorn_Beetle_Whitespotted_Sawyer_USA.jpg"},{"n":"Jewel Beetle","ord":"Coleoptera","fam":"Buprestidae","ha":"Forests, shrublands","di":"Plant nectar, wood (larvae)","si":"3-80 mm","ff":"Its iridescent elytra have been used in jewellery and embroidery for thousands of years.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Buprestidae%2C_Julodinae_sorted_by_color.jpg/500px-Buprestidae%2C_Julodinae_sorted_by_color.jpg"},{"n":"Tiger Beetle","ord":"Coleoptera","fam":"Carabidae","ha":"Sandy beaches, forest paths","di":"Ants, spiders, small insects","si":"8-20 mm","ff":"One of the fastest running insects, reaching up to 9 km/h — proportionally faster than a cheetah.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/5d/Leopard_Tiger_beetle_%28Lophyra_histrio%29_%2812072281006%29.jpg/500px-Leopard_Tiger_beetle_%28Lophyra_histrio%29_%2812072281006%29.jpg"},{"n":"Diving Beetle","ord":"Coleoptera","fam":"Dytiscidae","ha":"Freshwater ponds, streams","di":"Aquatic invertebrates, tadpoles, small fish","si":"15-40 mm","ff":"Carries an air bubble under its elytra to breathe underwater.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ad/Dytiscus_marginalis_01_by-dpckk.jpg/500px-Dytiscus_marginalis_01_by-dpckk.jpg"},{"n":"Weevil","ord":"Coleoptera","fam":"Curculionidae","ha":"Crops, forests, stored grains","di":"Plant material, seeds","si":"1-40 mm","ff":"With over 60,000 species, weevils form the largest family in the animal kingdom.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/Weevil_September_2008-1.jpg/500px-Weevil_September_2008-1.jpg"},{"n":"Click Beetle","ord":"Coleoptera","fam":"Elateridae","ha":"Forests, meadows","di":"Plant roots, other insects (larvae)","si":"7-20 mm","ff":"Snaps a spine on its body to flip itself upright with an audible click, reaching heights of 30 cm.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/09/Denticollis.linearis.3.jpg/500px-Denticollis.linearis.3.jpg"},{"n":"Ground Beetle","ord":"Coleoptera","fam":"Carabidae","ha":"Soil, leaf litter, gardens","di":"Other insects, worms","si":"5-35 mm","ff":"Many species can run at impressive speeds and are important predators of crop pests.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/95/Carabus_auratus_with_prey.jpg/500px-Carabus_auratus_with_prey.jpg"},{"n":"Bark Beetle","ord":"Coleoptera","fam":"Curculionidae","ha":"Coniferous and deciduous forests","di":"Bark and wood of trees","si":"1-9 mm","ff":"Bark beetle outbreaks have killed billions of trees across North America since the 1990s.","im":"https://upload.wikimedia.org/wikipedia/commons/e/e3/Dendroctonus_ponderosae.jpg"},{"n":"Monarch Butterfly","ord":"Lepidoptera","fam":"Nymphalidae","ha":"Meadows, gardens, forests","di":"Milkweed nectar (adults), milkweed leaves (caterpillars)","si":"89-102 mm wingspan","ff":"Migrates up to 4,800 km from Canada to Mexico each year — one of nature's greatest journeys.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/73/Monarch_Butterfly_Danaus_plexippus_Male_2664px.jpg/500px-Monarch_Butterfly_Danaus_plexippus_Male_2664px.jpg"},{"n":"Swallowtail Butterfly","ord":"Lepidoptera","fam":"Papilionidae","ha":"Gardens, woodlands, meadows","di":"Flower nectar (adults), leaves (caterpillars)","si":"65-100 mm wingspan","ff":"Named for the elongated tail extensions on hindwings; caterpillars mimic bird droppings for camouflage.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/26/Papilio_machaon_Mitterbach_01.jpg/500px-Papilio_machaon_Mitterbach_01.jpg"},{"n":"Blue Morpho Butterfly","ord":"Lepidoptera","fam":"Nymphalidae","ha":"Tropical rainforests of South America","di":"Rotting fruit, tree sap","si":"120-200 mm wingspan","ff":"Its vivid blue colour comes not from pigment but from microscopic scales that refract light.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d2/Common_blue_morpho_%28Morpho_helenor_helenor%29_head.JPG/500px-Common_blue_morpho_%28Morpho_helenor_helenor%29_head.JPG"},{"n":"Atlas Moth","ord":"Lepidoptera","fam":"Saturniidae","ha":"Tropical forests of Asia","di":"Does not eat as adult (no mouthparts)","si":"250-300 mm wingspan","ff":"Has no mouth as an adult; lives only 1-2 weeks solely to reproduce, fuelled by larval fat reserves.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/Attacus_atlas_qtl1.jpg/500px-Attacus_atlas_qtl1.jpg"},{"n":"Luna Moth","ord":"Lepidoptera","fam":"Saturniidae","ha":"Deciduous forests of North America","di":"Does not eat as adult","si":"75-105 mm wingspan","ff":"Its long tail-like hindwing extensions confuse bat echolocation, spinning sound away from its body.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d6/Actias_luna-male.jpg/500px-Actias_luna-male.jpg"},{"n":"Death's-head Hawkmoth","ord":"Lepidoptera","fam":"Sphingidae","ha":"Olive groves, gardens, wasteland","di":"Flower nectar, honey (raids beehives)","si":"80-120 mm wingspan","ff":"Named for the skull-like marking on its thorax; it squeaks when disturbed and invades beehives.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/04/Acherontia_lachesis_MHNT_Female_N%C3%AElg%C3%AEri_%28Tamil_Nadu%29_Dorsal.jpg/500px-Acherontia_lachesis_MHNT_Female_N%C3%AElg%C3%AEri_%28Tamil_Nadu%29_Dorsal.jpg"},{"n":"Peppered Moth","ord":"Lepidoptera","fam":"Geometridae","ha":"Woodlands, urban trees","di":"Tree bark lichens (caterpillars)","si":"45-62 mm wingspan","ff":"The classic textbook example of natural selection: industrial pollution caused dark variants to thrive.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/11/Biston_betularia_male.jpg/500px-Biston_betularia_male.jpg"},{"n":"Silk Moth","ord":"Lepidoptera","fam":"Bombycidae","ha":"Mulberry forests (domesticated)","di":"Mulberry leaves (caterpillars)","si":"40-60 mm wingspan","ff":"Has been domesticated for 5,000 years; a single cocoon can unravel into 1,500 m of continuous silk thread.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/Giant_silk_moth_%28Adelowalkeria_tristygma%29.jpg/500px-Giant_silk_moth_%28Adelowalkeria_tristygma%29.jpg"},{"n":"Painted Lady Butterfly","ord":"Lepidoptera","fam":"Nymphalidae","ha":"Open habitats worldwide","di":"Thistle, clover, asters","si":"45-73 mm wingspan","ff":"Undertakes a 14,400 km round-trip migration from Europe to sub-Saharan Africa — six generations complete it.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c4/Vanessa_cardui_on_Lavandula_angustifolia-2459.jpg/500px-Vanessa_cardui_on_Lavandula_angustifolia-2459.jpg"},{"n":"Six-spot Burnet Moth","ord":"Lepidoptera","fam":"Zygaenidae","ha":"Meadows, coastal grasslands","di":"Bird's-foot trefoil (caterpillars)","si":"25-35 mm wingspan","ff":"Its vivid red spots warn predators that it contains cyanide produced from the plants it eats.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2b/Zygaena_filipendulae_on_Avena_sativa.jpg/500px-Zygaena_filipendulae_on_Avena_sativa.jpg"},{"n":"European Honey Bee","ord":"Hymenoptera","fam":"Apidae","ha":"Meadows, gardens, orchards worldwide","di":"Nectar and pollen","si":"10-15 mm","ff":"A single colony can contain 60,000 bees; one bee produces only 1/12 teaspoon of honey in its lifetime.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/99/Apis_mellifera_flying.jpg/500px-Apis_mellifera_flying.jpg"},{"n":"Bumblebee","ord":"Hymenoptera","fam":"Apidae","ha":"Meadows, gardens, alpine areas","di":"Nectar and pollen","si":"8-25 mm","ff":"Can fly in temperatures too cold for honey bees by vibrating flight muscles to warm up.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c4/Bombus_lapidarius_-_Melilotus_officinalis_-_Tallinn.jpg/500px-Bombus_lapidarius_-_Melilotus_officinalis_-_Tallinn.jpg"},{"n":"Red Wood Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"Coniferous and mixed forests","di":"Insects, honeydew, seeds","si":"4-9 mm","ff":"Builds mound nests up to 2 m tall housing over 1 million individuals; mounds can be 700 years old.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/78/A_Formica_rufa_sideview.jpg/500px-A_Formica_rufa_sideview.jpg"},{"n":"Fire Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"Disturbed areas, grasslands, urban","di":"Seeds, insects, small vertebrates","si":"2-6 mm","ff":"Forms living rafts during floods by linking their bodies together, trapping air bubbles to stay afloat.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/af/Fire_ants.jpg/500px-Fire_ants.jpg"},{"n":"Leaf-cutter Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"Tropical and subtropical forests","di":"Fungus grown on leaf mulch","si":"1-16 mm","ff":"Discovered agriculture 50 million years before humans; their fungal gardens produce antibiotics.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/Atta_cephalotes-pjt.jpg/500px-Atta_cephalotes-pjt.jpg"},{"n":"Driver Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"African tropical forests","di":"Almost any animal prey","si":"3-13 mm","ff":"Colonies of up to 22 million ants move as a single 'super-organism' capable of killing large vertebrates.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c8/Dorylus_gribodoi_casent0172627_dorsal_1.jpg/500px-Dorylus_gribodoi_casent0172627_dorsal_1.jpg"},{"n":"Bullet Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"Rainforests of Central and South America","di":"Nectar, small arthropods","si":"18-30 mm","ff":"Delivers the most painful insect sting on the Schmidt scale; the pain reportedly lasts 24 hours.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cb/Paraponera_clavata.jpg/500px-Paraponera_clavata.jpg"},{"n":"Tarantula Hawk","ord":"Hymenoptera","fam":"Pompilidae","ha":"Deserts, scrublands","di":"Nectar (adults); tarantulas (larvae)","si":"25-50 mm","ff":"Paralyses tarantulas with a sting rated among the world's most painful, then lays a single egg on them.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/db/Tarantula_Hawk%2C_Southeastern_Colorado_P1270150b.jpg/500px-Tarantula_Hawk%2C_Southeastern_Colorado_P1270150b.jpg"},{"n":"Jewel Wasp","ord":"Hymenoptera","fam":"Ampulicidae","ha":"Tropical and subtropical regions","di":"Cockroaches (larvae), nectar (adults)","si":"15-22 mm","ff":"Injects a mind-controlling venom directly into a cockroach's brain, turning it into a docile food supply.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/03/Ampulex_compressa_%28Fabricius%2C_1781%29_The_Emerald_Cockroach_Wasp_or_Jewel_Wasp_%2815683609164%29.jpg/500px-Ampulex_compressa_%28Fabricius%2C_1781%29_The_Emerald_Cockroach_Wasp_or_Jewel_Wasp_%2815683609164%29.jpg"},{"n":"European Hornet","ord":"Hymenoptera","fam":"Vespidae","ha":"Forests, parks, orchards","di":"Insects, tree sap, fruit","si":"18-35 mm","ff":"Europe's largest eusocial wasp; can sting multiple times and hunts by night, unlike most wasps.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/Vespa_crabro_head_01.jpg/500px-Vespa_crabro_head_01.jpg"},{"n":"Yellow Jacket","ord":"Hymenoptera","fam":"Vespidae","ha":"Meadows, forests, urban areas","di":"Insects, sugary foods, carrion","si":"10-16 mm","ff":"Aggressive defenders of their nests; can communicate the location and size of food sources to nestmates.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/93/European_wasp_white_bg.jpg/500px-European_wasp_white_bg.jpg"},{"n":"Carpenter Ant","ord":"Hymenoptera","fam":"Formicidae","ha":"Forests, wooden structures","di":"Insects, honeydew, sugary foods","si":"6-13 mm","ff":"Excavates galleries in wood not for food but for nesting; a colony can survive over 25 years.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fb/Carpenter_ant_Tanzania_crop.jpg/500px-Carpenter_ant_Tanzania_crop.jpg"},{"n":"House Fly","ord":"Diptera","fam":"Muscidae","ha":"Human habitations worldwide","di":"Decaying organic matter, excrement","si":"6-7 mm","ff":"Tastes food with its feet (1,000× more sensitive than the human tongue) and vomits digestive juice onto it.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Common_house_fly%2C_Musca_domestica.jpg/500px-Common_house_fly%2C_Musca_domestica.jpg"},{"n":"Horse Fly","ord":"Diptera","fam":"Tabanidae","ha":"Near livestock, water bodies","di":"Blood (females), nectar (males)","si":"6-25 mm","ff":"Females cut skin with scissors-like mouthparts; their bite is one of the most painful insect bites.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Horse_fly_Tabanus_2.jpg/500px-Horse_fly_Tabanus_2.jpg"},{"n":"Hoverfly","ord":"Diptera","fam":"Syrphidae","ha":"Flowers, gardens, meadows","di":"Pollen, nectar (adults); aphids (larvae)","si":"8-18 mm","ff":"Mimics bees and wasps for protection despite being harmless; hovers motionless in the air for minutes.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/39/Syrphidae_poster.jpg/500px-Syrphidae_poster.jpg"},{"n":"Tsetse Fly","ord":"Diptera","fam":"Glossinidae","ha":"Sub-Saharan African savannas","di":"Blood of vertebrates","si":"8-17 mm","ff":"Transmits sleeping sickness (trypanosomiasis); has kept large areas of Africa free from cattle farming.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/be/Glossina-morsitans.jpg/500px-Glossina-morsitans.jpg"},{"n":"Mosquito","ord":"Diptera","fam":"Culicidae","ha":"Near standing water worldwide","di":"Blood (females), nectar (males)","si":"3-6 mm","ff":"Responsible for more human deaths than any other animal — over 700,000 per year through malaria alone.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d0/Aedes_aegypti.jpg/500px-Aedes_aegypti.jpg"},{"n":"Robber Fly","ord":"Diptera","fam":"Asilidae","ha":"Open habitats, forests, deserts","di":"Other insects (caught in flight)","si":"3-50 mm","ff":"Catches prey in mid-air and injects a venom that liquefies the victim's insides within seconds.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/25/Robber_fly_%28Promachus_sp.%29_female_with_bee_prey_Babadag.jpg/500px-Robber_fly_%28Promachus_sp.%29_female_with_bee_prey_Babadag.jpg"},{"n":"Crane Fly","ord":"Diptera","fam":"Tipulidae","ha":"Grasslands, gardens, wetlands","di":"Plant roots (larvae), rarely eats as adult","si":"10-60 mm","ff":"Despite resembling a giant mosquito, crane flies are harmless — most adults don't even eat.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e5/Crane_fly_%28Tipula_maxima%29.jpg/500px-Crane_fly_%28Tipula_maxima%29.jpg"},{"n":"Emperor Dragonfly","ord":"Odonata","fam":"Aeshnidae","ha":"Large ponds, lakes, slow rivers","di":"Flying insects, small fish","si":"70-84 mm","ff":"One of Europe's largest dragonflies; patrols fixed territories for hours, rarely landing.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/06/Anax_imperator_qtl2.jpg/500px-Anax_imperator_qtl2.jpg"},{"n":"Common Blue Damselfly","ord":"Odonata","fam":"Coenagrionidae","ha":"Ponds, canals, slow rivers","di":"Small flying insects","si":"29-31 mm","ff":"Males are blue and black; females mimic darker variants of males to avoid unwanted mating attempts.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0b/Common_blue_damselflies_%28Enallagma_cyathigerum%29_mating_composite.jpg/500px-Common_blue_damselflies_%28Enallagma_cyathigerum%29_mating_composite.jpg"},{"n":"Giant Petaltail","ord":"Odonata","fam":"Petaluridae","ha":"Swamps, bogs, wet forests","di":"Large insects, small vertebrates","si":"75-100 mm","ff":"One of the world's largest dragonflies, belonging to one of the oldest odonate lineages — 150 million years.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/2d/013323996_Petalura_ingentissima_dorsal.jpg/500px-013323996_Petalura_ingentissima_dorsal.jpg"},{"n":"Banded Demoiselle","ord":"Odonata","fam":"Calopterygidae","ha":"Streams and rivers with clear water","di":"Small aquatic and flying insects","si":"45-48 mm","ff":"Males perform elaborate fluttering courtship dances over water, folding and spreading iridescent wings.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Banded_demoiselle_damselfly_%28Calopteryx_splendens%29_male_4.jpg/500px-Banded_demoiselle_damselfly_%28Calopteryx_splendens%29_male_4.jpg"},{"n":"Desert Locust","ord":"Orthoptera","fam":"Acrididae","ha":"Arid and semi-arid regions of Africa and Asia","di":"All plant material","si":"40-60 mm","ff":"Swarms of billions can strip 35,000 tonnes of vegetation per day, threatening food security for millions.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f2/SGR_laying.jpg/500px-SGR_laying.jpg"},{"n":"Field Cricket","ord":"Orthoptera","fam":"Gryllidae","ha":"Grasslands, gardens, hedgerows","di":"Plants, small invertebrates","si":"17-25 mm","ff":"Only males chirp; the frequency of their chirps is temperature-dependent — you can calculate temperature from it.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/10/Gryllus_campestris_MHNT.jpg/500px-Gryllus_campestris_MHNT.jpg"},{"n":"Katydid","ord":"Orthoptera","fam":"Tettigoniidae","ha":"Tropical forests, meadows","di":"Leaves, flowers, small insects","si":"25-75 mm","ff":"Masters of camouflage, mimicking leaves down to fake bite marks and fungal spots to avoid predators.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/04/Bush-cricket_02_%28MK%29.JPG/500px-Bush-cricket_02_%28MK%29.JPG"},{"n":"Mole Cricket","ord":"Orthoptera","fam":"Gryllotalpidae","ha":"Moist soil near water","di":"Roots, worms, small insects","si":"25-45 mm","ff":"Digs acoustic chambers that amplify its mating calls like a megaphone, audible up to 500 m away.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cf/Gryllotalpa_gryllotalpa_01.JPG/500px-Gryllotalpa_gryllotalpa_01.JPG"},{"n":"Giant Weta","ord":"Orthoptera","fam":"Anostostomatidae","ha":"New Zealand forests","di":"Leaves, fruit, small invertebrates","si":"70-100 mm","ff":"One of the world's heaviest insects at up to 71 g; surviving on islands without mammalian predators.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/16/ORTH_Anostostomidae_Deinacrida_rugosa_in_habitat.png/500px-ORTH_Anostostomidae_Deinacrida_rugosa_in_habitat.png"},{"n":"European Mantis","ord":"Mantodea","fam":"Mantidae","ha":"Mediterranean shrublands, gardens","di":"Insects, small vertebrates","si":"40-75 mm","ff":"Can rotate its head 180°; females sometimes devour the male during or after mating.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/62/European_praying_mantis_%28Mantis_religiosa%29_green_female_Dobruja.jpg/500px-European_praying_mantis_%28Mantis_religiosa%29_green_female_Dobruja.jpg"},{"n":"Orchid Mantis","ord":"Mantodea","fam":"Hymenopodidae","ha":"Rainforests of Southeast Asia","di":"Insects, small vertebrates","si":"25-38 mm","ff":"Mimics orchid flowers so convincingly that pollinators land on it — one of nature's most spectacular disguises.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6d/Mantis_Hymenopus_coronatus_6_Luc_Viatour.jpg/500px-Mantis_Hymenopus_coronatus_6_Luc_Viatour.jpg"},{"n":"Dead Leaf Mantis","ord":"Mantodea","fam":"Mantidae","ha":"Tropical forests","di":"Insects","si":"55-65 mm","ff":"Its body, wing venation, and even fake bite marks mimic a dead leaf perfectly from every angle.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9f/Dead_Leaf.jpg/500px-Dead_Leaf.jpg"},{"n":"Stick Insect","ord":"Phasmatodea","fam":"Phasmatidae","ha":"Tropical and subtropical forests","di":"Leaves and bark","si":"50-300 mm","ff":"The world's longest insect (Chan's megastick) reaches 64 cm with legs extended.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0d/Le_Caylar_fg01.JPG/500px-Le_Caylar_fg01.JPG"},{"n":"Leaf Insect","ord":"Phasmatodea","fam":"Phylliidae","ha":"Tropical forests of South and Southeast Asia","di":"Leaves of forest trees","si":"40-100 mm","ff":"Mimics a leaf so precisely — including veins, uneven edges, and mould spots — that predators walk right past.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7d/Phyllium_jacobsoni_-_pair_1.jpg/500px-Phyllium_jacobsoni_-_pair_1.jpg"},{"n":"Water Strider","ord":"Hemiptera","fam":"Gerridae","ha":"Calm freshwater surfaces","di":"Trapped insects, larvae","si":"10-20 mm","ff":"Walks on water using surface tension; tiny hairs on its feet trap air, creating water-repellent cushions.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/af/Water_strider_%28Gerridae_sp.%29_Makiling.jpg/500px-Water_strider_%28Gerridae_sp.%29_Makiling.jpg"},{"n":"Assassin Bug","ord":"Hemiptera","fam":"Reduviidae","ha":"Forests, gardens, dry habitats","di":"Other insects, occasionally blood","si":"10-40 mm","ff":"Injects dissolving saliva into prey, then sucks out liquefied contents; some species transmit Chagas disease.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/63/Assassin_bug_%28Rhynocoris_iracundus%29_with_bee_%28Apis_ssp%29_prey.jpg/500px-Assassin_bug_%28Rhynocoris_iracundus%29_with_bee_%28Apis_ssp%29_prey.jpg"},{"n":"Shield Bug","ord":"Hemiptera","fam":"Pentatomidae","ha":"Gardens, woodland edges, crops","di":"Plant sap, some prey on insects","si":"8-18 mm","ff":"Named for their heraldic shield shape; emits a foul smell from glands when threatened — the 'stink bug'.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a8/Nezara_viridula2.jpg/500px-Nezara_viridula2.jpg"},{"n":"Cicada","ord":"Hemiptera","fam":"Cicadidae","ha":"Forests and scrublands worldwide","di":"Tree xylem sap","si":"18-60 mm","ff":"Some North American species spend 13 or 17 years underground before emerging in synchronised mass events.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a1/Cicada_-_Neotibicen_linnei%2C_Woodbridge%2C_Virginia.jpg/500px-Cicada_-_Neotibicen_linnei%2C_Woodbridge%2C_Virginia.jpg"},{"n":"Aphid","ord":"Hemiptera","fam":"Aphididae","ha":"Plants worldwide","di":"Plant sap","si":"1-10 mm","ff":"Can reproduce without males (parthenogenesis); one aphid could theoretically give rise to billions in a summer.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/51/Aphids_September_2008-1.jpg/500px-Aphids_September_2008-1.jpg"},{"n":"Giant Water Bug","ord":"Hemiptera","fam":"Belostomatidae","ha":"Freshwater ponds, slow streams","di":"Insects, tadpoles, small fish, frogs","si":"25-65 mm","ff":"Grabs prey larger than itself, injects digestive enzymes, and sucks out the dissolved tissue.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/33/Toe-Biter.jpg/500px-Toe-Biter.jpg"},{"n":"Madagascar Hissing Cockroach","ord":"Blattodea","fam":"Blaberidae","ha":"Decaying logs in Madagascan forests","di":"Decaying plant material","si":"50-75 mm","ff":"Produces a loud hiss by forcing air through modified breathing holes; males use it to fight rivals.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Female_Madagascar_hissing_cockroach.JPG/500px-Female_Madagascar_hissing_cockroach.JPG"},{"n":"American Cockroach","ord":"Blattodea","fam":"Blattidae","ha":"Warm, damp buildings worldwide","di":"Almost any organic material","si":"35-40 mm","ff":"Can survive up to a week without its head — it dies from dehydration, not from the decapitation itself.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3b/American-cockroach.jpg/500px-American-cockroach.jpg"},{"n":"Mound-building Termite","ord":"Blattodea","fam":"Termitidae","ha":"African and Australian savannas","di":"Dead plant material, wood","si":"5-15 mm","ff":"Builds mounds up to 9 m tall with internal ventilation shafts maintaining a constant 31°C inside.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/33/Macrotermes_bellicosus_minor_soldier.jpg/500px-Macrotermes_bellicosus_minor_soldier.jpg"},{"n":"Antlion","ord":"Neuroptera","fam":"Myrmeleontidae","ha":"Sandy soils in warm regions","di":"Ants and small insects (larvae)","si":"25-40 mm","ff":"Larvae dig conical sand traps and bury themselves at the bottom, ambushing insects that fall in.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Distoleon_tetragrammicus01.jpg/500px-Distoleon_tetragrammicus01.jpg"},{"n":"Lacewing","ord":"Neuroptera","fam":"Chrysopidae","ha":"Gardens, meadows, forests","di":"Aphids, mites, small insects","si":"10-30 mm","ff":"Lays eggs on silk stalks to prevent larvae from eating each other before hatching.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/57/Chrysopidae_01_%28MK%29.jpg/500px-Chrysopidae_01_%28MK%29.jpg"},{"n":"Caddisfly","ord":"Trichoptera","fam":"Limnephilidae","ha":"Freshwater streams and rivers","di":"Algae, detritus (larvae); does not eat much as adult","si":"5-25 mm","ff":"Larvae build protective cases from gravel, twigs, or sand; some species inspire biomimicry research.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d7/Trichoptera_caddisfly_1.jpg/500px-Trichoptera_caddisfly_1.jpg"},{"n":"Cat Flea","ord":"Siphonaptera","fam":"Pulicidae","ha":"Domestic environments worldwide","di":"Blood of mammals","si":"1-3 mm","ff":"Can jump 150× its own height — proportionally one of the greatest jumps in the animal kingdom.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/%D0%9A%D0%BE%D1%88%D0%B0%D1%87%D1%8C%D1%8F_%D0%B1%D0%BB%D0%BE%D1%85%D0%B0.jpg/500px-%D0%9A%D0%BE%D1%88%D0%B0%D1%87%D1%8C%D1%8F_%D0%B1%D0%BB%D0%BE%D1%85%D0%B0.jpg"},{"n":"Common Earwig","ord":"Dermaptera","fam":"Forficulidae","ha":"Gardens, leaf litter, under bark","di":"Plants, small insects, decaying matter","si":"12-15 mm","ff":"Exhibits rare maternal care among insects — mothers guard and clean their eggs until hatching.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0d/%28MHNT%29_Forficula_auricularia_%28female%29.jpg/500px-%28MHNT%29_Forficula_auricularia_%28female%29.jpg"},{"n":"Silverfish","ord":"Zygentoma","fam":"Lepismatidae","ha":"Dark, humid buildings worldwide","di":"Starch, paper, fabric, moulds","si":"12-19 mm","ff":"Among the most evolutionarily ancient insects, virtually unchanged for 400 million years; has no wings.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/84/LepismaSaccharina.jpg/500px-LepismaSaccharina.jpg"},{"n":"Mayfly","ord":"Ephemeroptera","fam":"Ephemeridae","ha":"Near clean freshwater rivers and lakes","di":"Algae and detritus (nymphs); does not eat as adult","si":"5-30 mm","ff":"Adults live only a few hours to days — enough to reproduce — after spending up to 3 years as aquatic nymphs.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/49/Rhithrogena_germanica_subimago_on_Equisetum_hyemale.jpg/500px-Rhithrogena_germanica_subimago_on_Equisetum_hyemale.jpg"}]