[{"n":"Golden Eagle","ord":"Accipitriformes","fam":"Accipitridae","ha":"Mountains, open country, forests","di":"Mammals, birds, carrion","si":"66-102 cm, 1.8-2.3 m wingspan","sp":"Up to 240 km/h (150 mph) diving; ~50 km/h (31 mph) cruising","ff":"Can dive at over 240 km/h and carry prey heavier than itself; national symbol of 9 countries.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cc/015_Wild_Golden_Eagle_in_flight_at_Pfyn-Finges_%28Switzerland%29_Photo_by_Giles_Laurent.jpg/500px-015_Wild_Golden_Eagle_in_flight_at_Pfyn-Finges_%28Switzerland%29_Photo_by_Giles_Laurent.jpg"},{"n":"Bald Eagle","ord":"Accipitriformes","fam":"Accipitridae","ha":"Near large open water, coasts, rivers","di":"Fish, waterfowl, carrion","si":"71-96 cm, 1.8-2.3 m wingspan","sp":"~120 km/h (75 mph) diving; ~56 km/h (35 mph) cruising","ff":"The national bird of the United States; its distinctive white head only develops at age 4-5.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/66/Haliaeetus_leucocephalus_%28Linnaeus_1766%29.jpg/500px-Haliaeetus_leucocephalus_%28Linnaeus_1766%29.jpg"},{"n":"Harpy Eagle","ord":"Accipitriformes","fam":"Accipitridae","ha":"Tropical lowland rainforests","di":"Sloths, monkeys, large reptiles","si":"86-107 cm, 1.7-2.0 m wingspan","sp":"~80 km/h (50 mph)","ff":"The most powerful eagle in the world; its talons are the size of a grizzly bear's claws.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/51/New_Guinea_Harpy_Eagle._Harpyopsis_novaeguineae_%2848670906153%29.jpg/500px-New_Guinea_Harpy_Eagle._Harpyopsis_novaeguineae_%2848670906153%29.jpg"},{"n":"Osprey","ord":"Accipitriformes","fam":"Pandionidae","ha":"Near water worldwide","di":"Fish almost exclusively","si":"50-66 cm, 1.5-1.8 m wingspan","sp":"~130 km/h (81 mph) in a dive","ff":"Dives feet-first into water and has reversible outer toes and spiny foot-pads to grip slippery fish.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a0/Osprey_Perched_Snag_Heislerville.jpg/500px-Osprey_Perched_Snag_Heislerville.jpg"},{"n":"Red Kite","ord":"Accipitriformes","fam":"Accipitridae","ha":"Woodland edges, farmland, open country","di":"Carrion, small mammals, earthworms","si":"60-70 cm, 1.4-1.7 m wingspan","sp":"~80 km/h (50 mph)","ff":"Was extinct in England by 1871; a successful reintroduction programme starting 1989 restored thousands.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/4b/Milvus_milvus_R%28ThKraft%29.jpg/500px-Milvus_milvus_R%28ThKraft%29.jpg"},{"n":"Andean Condor","ord":"Cathartiformes","fam":"Cathartidae","ha":"Andean highlands and Pacific coasts","di":"Carrion of large animals","si":"100-130 cm, up to 3.3 m wingspan","sp":"~55 km/h (34 mph) soaring","ff":"Has the largest wingspan of any land bird; can glide 5 hours without flapping using thermal currents.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b9/AndeanCondorMale.jpg/500px-AndeanCondorMale.jpg"},{"n":"Secretary Bird","ord":"Accipitriformes","fam":"Sagittariidae","ha":"African open grasslands and savannas","di":"Snakes, lizards, small mammals","si":"112-152 cm tall","sp":"~30 km/h (19 mph) — mostly terrestrial","ff":"Stamps prey to death with its powerful legs, delivering kicks with the force of 5× its body weight.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/66/Secretary_bird_Mara_for_WC.jpg/500px-Secretary_bird_Mara_for_WC.jpg"},{"n":"White-tailed Eagle","ord":"Accipitriformes","fam":"Accipitridae","ha":"Large lakes, rivers, coasts","di":"Fish, waterfowl, carrion","si":"70-98 cm, 1.8-2.4 m wingspan","sp":"~70 km/h (43 mph)","ff":"Europe's largest eagle; was extinct in Britain by 1918 and successfully reintroduced from 1975.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6d/NZ7_5265_%2852812350718%29.jpg/500px-NZ7_5265_%2852812350718%29.jpg"},{"n":"Peregrine Falcon","ord":"Falconiformes","fam":"Falconidae","ha":"Cliffs, cities, open country worldwide","di":"Birds caught in flight","si":"34-58 cm, 0.9-1.2 m wingspan","sp":"Over 389 km/h (242 mph) diving — fastest animal on Earth","ff":"The fastest animal on Earth; in level flight it reaches ~100 km/h (62 mph), but its record stoop exceeds 389 km/h.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/93/Falco_peregrinus_MHNT.ZOO.2010.11.102.1.jpg/500px-Falco_peregrinus_MHNT.ZOO.2010.11.102.1.jpg"},{"n":"Common Kestrel","ord":"Falconiformes","fam":"Falconidae","ha":"Open farmland, moorland, roadsides","di":"Voles, mice, small birds, insects","si":"27-35 cm, 0.7-0.8 m wingspan","sp":"~35-40 km/h (22-25 mph) hovering; ~60 km/h (37 mph) in flight","ff":"The only European bird able to hover in still air, using its tail as a rudder while scanning below.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/24/Common_kestrel_falco_tinnunculus.jpg/500px-Common_kestrel_falco_tinnunculus.jpg"},{"n":"Merlin","ord":"Falconiformes","fam":"Falconidae","ha":"Open moorland, coasts, grasslands","di":"Small birds, dragonflies","si":"25-30 cm, 0.5-0.7 m wingspan","sp":"~90-100 km/h (56-62 mph)","ff":"The smallest European falcon; females are larger than males and may pursue prey three times their size.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/79/Arthur-Pyle_The_Enchanter_Merlin.JPG/500px-Arthur-Pyle_The_Enchanter_Merlin.JPG"},{"n":"Barn Owl","ord":"Strigiformes","fam":"Tytonidae","ha":"Open farmland, meadows, woodland edges","di":"Voles, mice, shrews","si":"29-44 cm, 0.8-0.95 m wingspan","sp":"~25 km/h (16 mph) — near-silent flight","ff":"Its heart-shaped facial disc acts like a satellite dish, locating prey by sound alone in total darkness.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9e/American_Barn_Owl_%28Tyto_furcata_guatemalae%29%2C_Orange_Walk.jpg/500px-American_Barn_Owl_%28Tyto_furcata_guatemalae%29%2C_Orange_Walk.jpg"},{"n":"Great Horned Owl","ord":"Strigiformes","fam":"Strigidae","ha":"Forests, deserts, cities across the Americas","di":"Rabbits, skunks, other raptors","si":"46-63 cm, 1.0-1.5 m wingspan","sp":"~65 km/h (40 mph)","ff":"Has the most diverse diet of any North American raptor; regularly kills other owls and hawks.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/23/Bubo_virginianus_06.jpg/500px-Bubo_virginianus_06.jpg"},{"n":"Snowy Owl","ord":"Strigiformes","fam":"Strigidae","ha":"Arctic tundra, open fields in winter","di":"Lemmings, hares, birds","si":"53-65 cm, 1.25-1.5 m wingspan","sp":"~60 km/h (37 mph)","ff":"Active by day; lemming population cycles cause mass movements south — 'irruptions' — every few years.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f1/SnowyOwlAmericanBlackDuck.jpg/500px-SnowyOwlAmericanBlackDuck.jpg"},{"n":"Eurasian Eagle-Owl","ord":"Strigiformes","fam":"Strigidae","ha":"Mountains, forests, rocky ravines","di":"Rabbits, hedgehogs, small deer","si":"58-75 cm, 1.6-2.0 m wingspan","sp":"~50 km/h (31 mph)","ff":"Europe's largest owl; can kill prey as large as young roe deer and has no natural predators as an adult.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Bubo_bubo_3_%28Martin_Mecnarowski%29.jpg/500px-Bubo_bubo_3_%28Martin_Mecnarowski%29.jpg"},{"n":"European Robin","ord":"Passeriformes","fam":"Turdidae","ha":"Woodland, gardens, hedgerows","di":"Worms, insects, berries","si":"12-14 cm","sp":"~29 km/h (18 mph)","ff":"Famously tame around gardeners; has a quantum compass using entangled electrons to navigate by Earth's magnetic field.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/Erithacus_rubecula_with_cocked_head.jpg/500px-Erithacus_rubecula_with_cocked_head.jpg"},{"n":"Common Nightingale","ord":"Passeriformes","fam":"Muscicapidae","ha":"Dense thickets, woodland undergrowth","di":"Insects, worms, berries","si":"15-16.5 cm","sp":"~25 km/h (16 mph)","ff":"Sings by night as well as day; its song has 1,000+ distinct sounds and inspired Keats, Shelley, and Brahms.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f1/Luscinia_megarhynchos_-_Common_nightingale_-_Nachtegaal_%28cropped%29.jpg/500px-Luscinia_megarhynchos_-_Common_nightingale_-_Nachtegaal_%28cropped%29.jpg"},{"n":"Barn Swallow","ord":"Passeriformes","fam":"Hirundinidae","ha":"Open countryside near water and buildings","di":"Flying insects","si":"14-19 cm, 0.3-0.35 m wingspan","sp":"~40-50 km/h (25-31 mph); bursts up to 75 km/h (47 mph)","ff":"Migrates up to 10,000 km between Europe and South Africa; navigates with an internal magnetic map.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d4/Hirundo_rustica_Ormoz.jpg/500px-Hirundo_rustica_Ormoz.jpg"},{"n":"Common Raven","ord":"Passeriformes","fam":"Corvidae","ha":"Forests, mountains, arctic tundra","di":"Carrion, small animals, eggs, grains","si":"54-67 cm, 1.1-1.3 m wingspan","sp":"~48 km/h (30 mph)","ff":"Among the world's most intelligent animals; uses tools, plans for the future, and passes a mirror test.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/Corvus_corax_clarionensis%2C_Point_Reyes_National_Seashore.jpg/500px-Corvus_corax_clarionensis%2C_Point_Reyes_National_Seashore.jpg"},{"n":"Eurasian Jay","ord":"Passeriformes","fam":"Corvidae","ha":"Woodland, parks, gardens","di":"Acorns, insects, eggs, small birds","si":"32-35 cm","sp":"~25-30 km/h (16-19 mph)","ff":"Buries up to 5,000 acorns per autumn and remembers nearly all locations — planting thousands of oak trees.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6d/Garrulus_glandarius_1_Luc_Viatour.jpg/500px-Garrulus_glandarius_1_Luc_Viatour.jpg"},{"n":"Common Swift","ord":"Apodiformes","fam":"Apodidae","ha":"Skies over cities, towns and open country","di":"Flying insects and spiders","si":"16-17 cm, 0.4-0.44 m wingspan","sp":"Up to 111 km/h (69 mph) — fastest level-flying bird","ff":"Spends almost its entire life airborne — sleeping, mating, and feeding in flight; lands only to nest.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Common_Swift_2025_07_18_02_%28cropped%29.jpg/500px-Common_Swift_2025_07_18_02_%28cropped%29.jpg"},{"n":"European Goldfinch","ord":"Passeriformes","fam":"Fringillidae","ha":"Gardens, woodland edges, farmland","di":"Seeds, especially thistles","si":"12-13 cm","sp":"~40 km/h (25 mph)","ff":"Its slender beak is perfectly shaped to extract seeds from thistles and teasels that other birds cannot reach.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/eb/072_Wild_European_goldfinch_at_the_Parc_Jura_vaudois_Photo_by_Giles_Laurent.jpg/500px-072_Wild_European_goldfinch_at_the_Parc_Jura_vaudois_Photo_by_Giles_Laurent.jpg"},{"n":"Common Starling","ord":"Passeriformes","fam":"Sturnidae","ha":"Farmland, parks, urban areas","di":"Invertebrates, fruit, scraps","si":"19-22 cm","sp":"~77 km/h (48 mph)","ff":"Forms murmurations — synchronised aerial flocks of millions — where each bird tracks its 7 nearest neighbours.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/af/Common_starling_%28Sturnus_vulgaris%29_breeding_male_Marken.jpg/500px-Common_starling_%28Sturnus_vulgaris%29_breeding_male_Marken.jpg"},{"n":"Eurasian Wren","ord":"Passeriformes","fam":"Troglodytidae","ha":"Dense undergrowth, woodland, gardens","di":"Insects, spiders, small invertebrates","si":"9-10 cm","sp":"~25 km/h (16 mph)","ff":"One of the loudest birds for its size; its song is 10× louder per unit mass than a rooster's crow.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Eurasian_wren_Franconville_02.jpg/500px-Eurasian_wren_Franconville_02.jpg"},{"n":"Song Thrush","ord":"Passeriformes","fam":"Turdidae","ha":"Woodland, gardens, hedgerows","di":"Snails, worms, berries","si":"20-22 cm","sp":"~40 km/h (25 mph)","ff":"One of very few birds that uses a tool — a stone 'anvil' to smash open snail shells.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1e/%D0%9F%D0%B5%D0%B2%D1%87%D0%B8%D0%B9_%D0%B4%D1%80%D0%BE%D0%B7%D0%B4_%D0%BD%D0%B0_%D0%BF%D0%B5%D0%BD%D1%8C%D0%BA%D0%B5_%28Turdus_philomelos%29%2C_%D0%91%D0%B8%D1%82%D1%86%D0%B5%D0%B2%D1%81%D0%BA%D0%B8%D0%B9_%D0%BB%D0%B5%D1%81.jpg/500px-%D0%9F%D0%B5%D0%B2%D1%87%D0%B8%D0%B9_%D0%B4%D1%80%D0%BE%D0%B7%D0%B4_%D0%BD%D0%B0_%D0%BF%D0%B5%D0%BD%D1%8C%D0%BA%D0%B5_%28Turdus_philomelos%29%2C_%D0%91%D0%B8%D1%82%D1%86%D0%B5%D0%B2%D1%81%D0%BA%D0%B8%D0%B9_%D0%BB%D0%B5%D1%81.jpg"},{"n":"White Stork","ord":"Ciconiiformes","fam":"Ciconiidae","ha":"Open farmland, wetlands near human habitation","di":"Frogs, insects, small mammals, fish","si":"100-115 cm, 1.55-2.15 m wingspan","sp":"~45 km/h (28 mph)","ff":"Migrates up to 20,000 km between Europe and sub-Saharan Africa; returns to the same nest each year.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fb/Ciconia_ciconia_-_01.jpg/500px-Ciconia_ciconia_-_01.jpg"},{"n":"Grey Heron","ord":"Pelecaniformes","fam":"Ardeidae","ha":"Rivers, lakes, estuaries, marshes","di":"Fish, frogs, small mammals, birds","si":"84-102 cm, 1.55-1.75 m wingspan","sp":"~47 km/h (29 mph)","ff":"Can stand motionless for hours then strike at 120 km/h (75 mph) with its spear-like bill.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1b/Ardea_cinerea_2013-09-16.jpg/500px-Ardea_cinerea_2013-09-16.jpg"},{"n":"Great White Egret","ord":"Pelecaniformes","fam":"Ardeidae","ha":"Wetlands, rivers, coasts worldwide","di":"Fish, frogs, aquatic invertebrates","si":"80-104 cm, 1.3-1.7 m wingspan","sp":"~42 km/h (26 mph)","ff":"Was hunted nearly to extinction in the 19th century for its breeding plumes used in ladies' hats.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a7/Great_Egret_%28Ardea_alba%29_in_Breeding_Plumage%2C_Cape_May_County%2C_New_Jersey%2C_USA_%28cropped%29.png/500px-Great_Egret_%28Ardea_alba%29_in_Breeding_Plumage%2C_Cape_May_County%2C_New_Jersey%2C_USA_%28cropped%29.png"},{"n":"Great Frigatebird","ord":"Suliformes","fam":"Fregatidae","ha":"Tropical ocean islands","di":"Fish, squid, stolen food","si":"86-114 cm, 2.05-2.3 m wingspan","sp":"Up to 153 km/h (95 mph)","ff":"Males inflate a bright-red throat pouch like a balloon for up to 20 minutes to attract females.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/20/Male_greater_frigate_bird_displaying.jpg/500px-Male_greater_frigate_bird_displaying.jpg"},{"n":"Greater Flamingo","ord":"Phoenicopteriformes","fam":"Phoenicopteridae","ha":"Saline or alkaline lakes and lagoons","di":"Algae, brine shrimp, small invertebrates","si":"110-150 cm tall","sp":"~50-60 km/h (31-37 mph)","ff":"Its pink colour comes entirely from carotenoid pigments in its food; captive flamingos fed plain diets turn white.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/81/010_Greater_flamingos_male_and_female_in_the_Camargue_during_mating_season_Photo_by_Giles_Laurent.jpg/500px-010_Greater_flamingos_male_and_female_in_the_Camargue_during_mating_season_Photo_by_Giles_Laurent.jpg"},{"n":"Emperor Penguin","ord":"Sphenisciformes","fam":"Spheniscidae","ha":"Antarctic sea ice and surrounding ocean","di":"Fish, squid, krill","si":"110-130 cm tall","sp":"Flightless — swims at up to 25 km/h (16 mph)","ff":"Breeds in -60°C (-76°F) blizzards; males fast for 4 months while incubating a single egg on their feet.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Aptenodytes_forsteri_-Snow_Hill_Island%2C_Antarctica_-adults_and_juvenile-8.jpg/500px-Aptenodytes_forsteri_-Snow_Hill_Island%2C_Antarctica_-adults_and_juvenile-8.jpg"},{"n":"Little Blue Penguin","ord":"Sphenisciformes","fam":"Spheniscidae","ha":"Coasts of southern Australia and New Zealand","di":"Small fish, squid, krill","si":"30-33 cm tall","sp":"Flightless — swims at ~6 km/h (4 mph)","ff":"The world's smallest penguin; returns to the same burrow each year and may live over 20 years.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/38/Eudyptula_minor_Bruny_1.jpg/500px-Eudyptula_minor_Bruny_1.jpg"},{"n":"African Penguin","ord":"Sphenisciformes","fam":"Spheniscidae","ha":"Coasts and islands of southern Africa","di":"Anchovies, sardines, squid","si":"60-70 cm tall","sp":"Flightless — swims at up to 20 km/h (12 mph)","ff":"Also called the 'jackass penguin' for its donkey-like bray; listed as Endangered due to fish stock collapse.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/55/Wikimania_2018%2C_Cape_Town_%28_1050602%29%2C_crop.jpg/500px-Wikimania_2018%2C_Cape_Town_%28_1050602%29%2C_crop.jpg"},{"n":"Wandering Albatross","ord":"Procellariiformes","fam":"Diomedeidae","ha":"Southern Ocean, subantarctic islands","di":"Squid, fish, carrion","si":"107-135 cm, 2.5-3.5 m wingspan","sp":"~120 km/h (75 mph); cruises at ~55 km/h (34 mph)","ff":"Has the longest wingspan of any living bird; can circle the globe in 46 days using dynamic soaring without flapping.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/aa/Diomedea_exulans_-_SE_Tasmania.jpg/500px-Diomedea_exulans_-_SE_Tasmania.jpg"},{"n":"Atlantic Puffin","ord":"Charadriiformes","fam":"Alcidae","ha":"North Atlantic coasts and open ocean","di":"Sand eels, small fish","si":"26-29 cm","sp":"~88 km/h (55 mph)","ff":"Can carry up to 62 fish crosswise in its beak at once thanks to spines on its palate.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/23/027_Atlantic_puffin_in_flight_with_mouth_full_of_fishes_Photo_by_Giles_Laurent.jpg/500px-027_Atlantic_puffin_in_flight_with_mouth_full_of_fishes_Photo_by_Giles_Laurent.jpg"},{"n":"Arctic Tern","ord":"Charadriiformes","fam":"Laridae","ha":"Arctic and subarctic coasts","di":"Small fish, invertebrates","si":"28-39 cm, 0.65-0.75 m wingspan","sp":"~40 km/h (25 mph)","ff":"Makes the longest migration of any animal — 90,000 km (56,000 mi) round trip from Arctic to Antarctic each year.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0b/250_Arctic_Tern_restored.jpg/500px-250_Arctic_Tern_restored.jpg"},{"n":"Common Gannet","ord":"Suliformes","fam":"Sulidae","ha":"North Atlantic coasts and open sea","di":"Mackerel, herring, sand eels","si":"81-110 cm, 1.7-2.0 m wingspan","sp":"~100 km/h (62 mph) diving","ff":"Dives from 30 m (100 ft) at 100 km/h, hitting water like an arrow; air sacs in its skull cushion the impact.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/cb/Common_Murres_%28Uria_aalge%29_and_a_Northern_Gannet_%28Morus_bassanus%29_-_Her%C3%B8y%2C_Norway_2022-07-05.jpg/500px-Common_Murres_%28Uria_aalge%29_and_a_Northern_Gannet_%28Morus_bassanus%29_-_Her%C3%B8y%2C_Norway_2022-07-05.jpg"},{"n":"Blue-footed Booby","ord":"Suliformes","fam":"Sulidae","ha":"Pacific coasts of the Americas","di":"Fish, caught in plunge-dives","si":"76-84 cm","sp":"~97 km/h (60 mph) diving","ff":"Males show off their vivid blue feet in a high-stepping dance; brighter feet signal better health to females.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3b/Blue-footed-booby.jpg/500px-Blue-footed-booby.jpg"},{"n":"Mute Swan","ord":"Anseriformes","fam":"Anatidae","ha":"Lakes, rivers, estuaries","di":"Aquatic plants, algae, small invertebrates","si":"125-170 cm, 2.0-2.4 m wingspan","sp":"~88 km/h (55 mph)","ff":"The heaviest flying bird in the UK; young cygnets hitch rides on their parents' backs for protection.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7b/Mute_Swan_Emsworth2.JPG/500px-Mute_Swan_Emsworth2.JPG"},{"n":"Mallard","ord":"Anseriformes","fam":"Anatidae","ha":"Wetlands, parks, rivers worldwide","di":"Seeds, aquatic plants, invertebrates","si":"50-65 cm","sp":"~55-60 km/h (34-37 mph)","ff":"Ancestor of almost all domestic duck breeds; males grow a new set of feathers after breeding season.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bf/Anas_platyrhynchos_male_female_quadrat.jpg/500px-Anas_platyrhynchos_male_female_quadrat.jpg"},{"n":"Canada Goose","ord":"Anseriformes","fam":"Anatidae","ha":"Parks, farmland, rivers, lakes","di":"Grass, aquatic plants, grain","si":"75-110 cm, 1.3-1.8 m wingspan","sp":"~65 km/h (40 mph)","ff":"Pairs mate for life and mourn lost partners; can navigate thousands of kilometres using the sun and stars.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/40/Canada_goose.jpg/500px-Canada_goose.jpg"},{"n":"Mandarin Duck","ord":"Anseriformes","fam":"Anatidae","ha":"Wooded ponds and rivers in East Asia","di":"Seeds, plants, small fish, insects","si":"41-49 cm","sp":"~65 km/h (40 mph)","ff":"Considered a symbol of fidelity in East Asia; the male's spectacular plumage is considered one of the most beautiful of any bird.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/43/Pair_of_mandarin_ducks.jpg/500px-Pair_of_mandarin_ducks.jpg"},{"n":"Hyacinth Macaw","ord":"Psittaciformes","fam":"Psittacidae","ha":"Palm swamps and woodlands of South America","di":"Palm nuts, seeds, fruit","si":"100 cm, 1.2-1.4 m wingspan","sp":"~56-60 km/h (35-37 mph)","ff":"The world's largest parrot by length; its beak can crack a coconut shell and generates enormous force.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/05/008_Hyacinth_macaw_couple_kissing_under_Pink_Ip%C3%AA_tree_in_Encontro_das_%C3%81guas_State_Park_Photo_by_Giles_Laurent.jpg/500px-008_Hyacinth_macaw_couple_kissing_under_Pink_Ip%C3%AA_tree_in_Encontro_das_%C3%81guas_State_Park_Photo_by_Giles_Laurent.jpg"},{"n":"Scarlet Macaw","ord":"Psittaciformes","fam":"Psittacidae","ha":"Tropical rainforests of Central and South America","di":"Seeds, nuts, fruit, clay (for minerals)","si":"81 cm, 1.0-1.1 m wingspan","sp":"~56 km/h (35 mph)","ff":"Eats toxic seeds safely by visiting clay licks — the minerals neutralise plant poisons in its digestive system.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/Scarlet_macaw_%28Ara_macao_cyanopterus%29_Copan.jpg/500px-Scarlet_macaw_%28Ara_macao_cyanopterus%29_Copan.jpg"},{"n":"African Grey Parrot","ord":"Psittaciformes","fam":"Psittacidae","ha":"West and Central African rainforests","di":"Seeds, nuts, fruit, leaves","si":"33-41 cm","sp":"~40 km/h (25 mph)","ff":"The most cognitively advanced bird; Alex, a famous individual, learned over 100 words and could count to 6.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/68/African_Grey_Parrot%2C_peeking_out_from_under_its_wing_-_edit.jpg/500px-African_Grey_Parrot%2C_peeking_out_from_under_its_wing_-_edit.jpg"},{"n":"Kakapo","ord":"Psittaciformes","fam":"Strigopidae","ha":"New Zealand forests (now only offshore islands)","di":"Plants, seeds, fruit, pollen","si":"58-64 cm","sp":"Flightless","ff":"The world's only flightless parrot and heaviest; critically endangered with only ~200 individuals remaining.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b1/Kakapo_Sirocco_1.jpg/500px-Kakapo_Sirocco_1.jpg"},{"n":"Kea","ord":"Psittaciformes","fam":"Nestoridae","ha":"Alpine zones of New Zealand's South Island","di":"Plant matter, invertebrates, carrion, garbage","si":"46-50 cm","sp":"~60 km/h (37 mph)","ff":"The world's only alpine parrot; dismantles cars for entertainment and scores as high as primates in problem-solving tests.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/34/Nestor_notabilis_-Fiordland%2C_New_Zealand-8b.jpg/500px-Nestor_notabilis_-Fiordland%2C_New_Zealand-8b.jpg"},{"n":"Common Ostrich","ord":"Struthioniformes","fam":"Struthionidae","ha":"African savannas and deserts","di":"Seeds, plants, insects, lizards","si":"175-275 cm tall","sp":"Flightless — runs at up to 70 km/h (43 mph); fastest bird on land","ff":"The world's largest and fastest running bird, reaching 70 km/h; its eye (5 cm / 2 in) is bigger than its brain.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Struthio_camelus_-_Etosha_2014_%283%29.jpg/500px-Struthio_camelus_-_Etosha_2014_%283%29.jpg"},{"n":"Emu","ord":"Casuariiformes","fam":"Casuariidae","ha":"Australian grasslands, scrublands, forests","di":"Plants, insects, small vertebrates","si":"150-190 cm tall","sp":"Flightless — runs at up to 50 km/h (31 mph)","ff":"Second largest bird; Australia lost the 'Emu War' of 1932 — soldiers failed to control wild emu populations.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Emu_1_-_Tidbinbilla.jpg/500px-Emu_1_-_Tidbinbilla.jpg"},{"n":"Southern Cassowary","ord":"Casuariiformes","fam":"Casuariidae","ha":"Tropical rainforests of New Guinea and Australia","di":"Fruit, fungi, small vertebrates","si":"127-170 cm tall","sp":"Flightless — runs at up to 50 km/h (31 mph)","ff":"Considered the world's most dangerous bird; its inner toe bears a 12 cm (5 in) dagger-like claw.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/54/Southern_Cassowary_7071.jpg/500px-Southern_Cassowary_7071.jpg"},{"n":"North Island Brown Kiwi","ord":"Apterygiformes","fam":"Apterygidae","ha":"New Zealand forests","di":"Earthworms, insects, berries","si":"35-45 cm","sp":"Flightless — walks at ~3 km/h (2 mph)","ff":"New Zealand's national bird; has nostrils at the tip of its bill and the largest egg-to-body ratio of any bird.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/82/TeTuatahianui.jpg/500px-TeTuatahianui.jpg"},{"n":"Ruby-throated Hummingbird","ord":"Trochiliformes","fam":"Trochilidae","ha":"Eastern North America, gardens and forests","di":"Nectar, small insects","si":"7-9 cm","sp":"~48 km/h (30 mph); over 100 km/h (62 mph) in courtship dives","ff":"Beats its wings 53 times per second and is the only bird able to fly backwards, sideways, and hover.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Archilochus_colubris_-flying_-male-8.jpg/500px-Archilochus_colubris_-flying_-male-8.jpg"},{"n":"Bee Hummingbird","ord":"Trochiliformes","fam":"Trochilidae","ha":"Cuban forests and gardens","di":"Nectar, small insects","si":"5-6 cm","sp":"~40 km/h (25 mph); wings beat 80 times per second","ff":"The world's smallest bird; its egg is smaller than a coffee bean and its heart beats 1,200 times per minute.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bf/Bee_hummingbird_%28Mellisuga_helenae%29_immature_male.jpg/500px-Bee_hummingbird_%28Mellisuga_helenae%29_immature_male.jpg"},{"n":"Sword-billed Hummingbird","ord":"Trochiliformes","fam":"Trochilidae","ha":"Andean cloud forests","di":"Nectar from long tubular flowers","si":"12-14 cm + 10 cm bill","sp":"~45 km/h (28 mph)","ff":"The only bird with a bill longer than its body; co-evolved with passion flowers that only it can pollinate.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fa/Sword-billed_hummingbird_%28male%29_at_Guango_Lodge%2C_Ecuador_%2821310837273%29.jpg/500px-Sword-billed_hummingbird_%28male%29_at_Guango_Lodge%2C_Ecuador_%2821310837273%29.jpg"},{"n":"Great Spotted Woodpecker","ord":"Piciformes","fam":"Picidae","ha":"Woodland across Eurasia","di":"Insects (larvae), seeds, eggs, nestlings","si":"20-24 cm","sp":"~55 km/h (34 mph)","ff":"Drums up to 20 times per second; its brain is shock-absorbed by spongy bone and a hyoid bone that wraps around the skull.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/df/Great_spotted_woodpecker_%28Dendrocopos_major%29_male_Drenthe.jpg/500px-Great_spotted_woodpecker_%28Dendrocopos_major%29_male_Drenthe.jpg"},{"n":"Black Woodpecker","ord":"Piciformes","fam":"Picidae","ha":"Old-growth forests of Eurasia","di":"Wood-boring beetle larvae, ants","si":"40-46 cm","sp":"~60 km/h (37 mph)","ff":"Creates nest holes later used by owls, ducks, and martens; a single bird can excavate 100 litres of wood per year.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/20/%D0%96%D0%B5%D0%BB%D0%BD%D0%B0_%28Dryocopus_martius%2C_fem%29%2C_%C2%AB%D0%93%D0%BE%D1%80%D0%BE%D0%B4%D1%81%D0%BA%D0%B0%D1%8F_%D1%88%D1%83%D0%BC%D0%B0%D1%88%D0%B5%D1%88%D0%B0%D1%8F%C2%BB.jpg/500px-%D0%96%D0%B5%D0%BB%D0%BD%D0%B0_%28Dryocopus_martius%2C_fem%29%2C_%C2%AB%D0%93%D0%BE%D1%80%D0%BE%D0%B4%D1%81%D0%BA%D0%B0%D1%8F_%D1%88%D1%83%D0%BC%D0%B0%D1%88%D0%B5%D1%88%D0%B0%D1%8F%C2%BB.jpg"},{"n":"Toco Toucan","ord":"Piciformes","fam":"Ramphastidae","ha":"South American woodland and savanna","di":"Fruit, insects, eggs, small lizards","si":"55-65 cm","sp":"~65 km/h (40 mph)","ff":"Its enormous orange bill is a cooling radiator; blood flow to it increases in heat, releasing body warmth.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b0/006_Toco_toucan_in_Encontro_das_%C3%81guas_State_Park_Photo_by_Giles_Laurent.jpg/500px-006_Toco_toucan_in_Encontro_das_%C3%81guas_State_Park_Photo_by_Giles_Laurent.jpg"},{"n":"Common Kingfisher","ord":"Coraciiformes","fam":"Alcedinidae","ha":"Rivers, lakes, streams in Eurasia","di":"Small fish, aquatic invertebrates","si":"16-17 cm","sp":"~40 km/h (25 mph); dives at ~90 km/h (56 mph)","ff":"Dives at high speed; its beak inspired the design of Japan's Shinkansen bullet train nose to reduce sonic booms.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bc/Alcedo_atthis_-England-8_%28cropped%29.jpg/500px-Alcedo_atthis_-England-8_%28cropped%29.jpg"},{"n":"European Bee-eater","ord":"Coraciiformes","fam":"Meropidae","ha":"Open country, river banks, Mediterranean scrub","di":"Bees, wasps, dragonflies","si":"25-29 cm","sp":"~50 km/h (31 mph)","ff":"Catches bees in flight and rubs them against a perch to remove the sting before swallowing them.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c2/Bee-eater_%2819270331108%29.jpg/500px-Bee-eater_%2819270331108%29.jpg"},{"n":"Laughing Kookaburra","ord":"Coraciiformes","fam":"Alcedinidae","ha":"Australian open woodland and gardens","di":"Insects, reptiles, small vertebrates","si":"41-47 cm","sp":"~40 km/h (25 mph)","ff":"Its distinctive 'laughing' call announces territory; family groups use it as a dawn chorus to claim their patch.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/71/Laughing_Kookaburra_1.jpg/500px-Laughing_Kookaburra_1.jpg"},{"n":"Indian Peafowl","ord":"Galliformes","fam":"Phasianidae","ha":"South Asian forests and farmland","di":"Seeds, insects, small reptiles, berries","si":"100-115 cm + 140-160 cm train","sp":"~16 km/h (10 mph) walking; up to 60 km/h (37 mph) in flight","ff":"The male's train has 150-200 feathers with iridescent eyespots; Darwin found the peacock's tail troubling to his theory.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7f/Peacock_on_tree_%2852077240794%29.jpg/500px-Peacock_on_tree_%2852077240794%29.jpg"},{"n":"Common Pheasant","ord":"Galliformes","fam":"Phasianidae","ha":"Farmland, woodland edges, scrub","di":"Seeds, berries, insects, small animals","si":"55-90 cm","sp":"~60-70 km/h (37-43 mph) in bursts","ff":"Originally from Asia, introduced to Europe by Romans; now one of the world's most widely distributed gamebirds.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6e/Phasianus_colchicus_MHNT_Skeleton.jpg/500px-Phasianus_colchicus_MHNT_Skeleton.jpg"},{"n":"Rock Ptarmigan","ord":"Galliformes","fam":"Phasianidae","ha":"Arctic and alpine tundra","di":"Buds, leaves, berries, seeds","si":"31-35 cm","sp":"~50 km/h (31 mph)","ff":"Changes plumage three times a year — brown in summer, white in winter — a camouflage evolution unique among birds.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9c/Lagopus_muta_japonica_Mount_Tsubakuro.jpg/500px-Lagopus_muta_japonica_Mount_Tsubakuro.jpg"},{"n":"Bar-tailed Godwit","ord":"Charadriiformes","fam":"Scolopacidae","ha":"Arctic tundra (breeding), tidal flats (wintering)","di":"Invertebrates, marine worms","si":"37-41 cm","sp":"~100 km/h (62 mph) average over migration","ff":"Flies non-stop from Alaska to New Zealand — 11,000+ km (7,000 mi) in 11 days — the longest non-stop flight of any bird.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f5/Limosa_lapponica_2_-_Taren_Point.jpg/500px-Limosa_lapponica_2_-_Taren_Point.jpg"},{"n":"Eurasian Oystercatcher","ord":"Charadriiformes","fam":"Haematopodidae","ha":"Coasts, estuaries, inland grasslands","di":"Mussels, cockles, worms","si":"40-45 cm","sp":"~60 km/h (37 mph)","ff":"Can live over 40 years; uses one of two tactics to open shellfish — stabbing or hammering — and teaches it to chicks.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/43/Austernfischer_Haematopus_ostralegus_Iceland_RB.jpg/500px-Austernfischer_Haematopus_ostralegus_Iceland_RB.jpg"},{"n":"Rock Dove","ord":"Columbiformes","fam":"Columbidae","ha":"Cliffs, cities worldwide","di":"Seeds, grain, scraps","si":"29-37 cm","sp":"Up to 148 km/h (92 mph) — homing pigeon record","ff":"Ancestor of the domestic pigeon; used in both World Wars as a messenger and awarded the Dickin Medal for bravery.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3c/Common_pigeon_at_Waterlow_Park%2C_London_01.jpg/500px-Common_pigeon_at_Waterlow_Park%2C_London_01.jpg"},{"n":"Victoria Crowned Pigeon","ord":"Columbiformes","fam":"Columbidae","ha":"Lowland forests of New Guinea","di":"Fallen fruit, seeds, invertebrates","si":"66-74 cm","sp":"~25 km/h (16 mph)","ff":"The world's largest pigeon; named for Queen Victoria due to its extraordinary lacy blue crest.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/74/Goura_victoria_LC0384.jpg/500px-Goura_victoria_LC0384.jpg"},{"n":"Common Cuckoo","ord":"Cuculiformes","fam":"Cuculidae","ha":"Woodland, farmland, moorland","di":"Hairy caterpillars (especially toxic species other birds avoid)","si":"32-36 cm","sp":"~58 km/h (36 mph)","ff":"A brood parasite — lays eggs in other birds' nests; the chick evicts host eggs and is raised by unsuspecting foster parents.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b9/Cuckoo_%2851169010335%29.jpg/500px-Cuckoo_%2851169010335%29.jpg"},{"n":"Resplendent Quetzal","ord":"Trogoniformes","fam":"Trogonidae","ha":"Cloud forests of Central America","di":"Fruit (especially wild avocados), insects","si":"36-40 cm + 65 cm tail feathers","sp":"~35 km/h (22 mph)","ff":"Considered the most beautiful bird in the Americas; sacred to the Maya and Aztec — tail feathers were worth more than gold.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/80/Resplendent_quetzal_san_gerardo_de_dota_3.31.24_DSC_3989-topaz-denoiseraw.jpg/500px-Resplendent_quetzal_san_gerardo_de_dota_3.31.24_DSC_3989-topaz-denoiseraw.jpg"},{"n":"Superb Lyrebird","ord":"Passeriformes","fam":"Menuridae","ha":"Australian temperate rainforests","di":"Insects, worms, spiders","si":"74-98 cm","sp":"~25 km/h (16 mph) — mostly ground-dwelling","ff":"The world's greatest mimic — reproduces chainsaws, camera shutters, and other bird species with perfect accuracy.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ae/Superb_lyrbird_in_scrub.jpg/500px-Superb_lyrbird_in_scrub.jpg"},{"n":"Eurasian Blackbird","ord":"Passeriformes","fam":"Turdidae","ha":"Woodland, gardens, hedgerows","di":"Worms, berries, insects","si":"24-25 cm","sp":"~40 km/h (25 mph)","ff":"One of the first birds to sing each morning; males sing 170+ distinct phrases, often incorporating urban sounds.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Common_Blackbird_%28Turdus_merula_mauritanicus%29_female.jpg/500px-Common_Blackbird_%28Turdus_merula_mauritanicus%29_female.jpg"},{"n":"House Sparrow","ord":"Passeriformes","fam":"Passeridae","ha":"Human habitations worldwide","di":"Seeds, grain, insects","si":"14-16 cm","sp":"~45 km/h (28 mph)","ff":"Has lived alongside humans for 10,000 years; found on every continent except Antarctica.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9b/House_sparrow_male_in_Prospect_Park_%2853532%29.jpg/500px-House_sparrow_male_in_Prospect_Park_%2853532%29.jpg"},{"n":"Great White Pelican","ord":"Pelecaniformes","fam":"Pelecanidae","ha":"Large freshwater lakes, rivers, deltas","di":"Fish","si":"140-180 cm, 2.3-2.8 m wingspan","sp":"~56 km/h (35 mph)","ff":"Its pouch holds 13 litres (3.4 gallons) — three times its stomach; groups form a semicircle to herd fish before scooping.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/01/Great_white_pelican_%28Pelecanus_onocrotalus%29_head.jpg/500px-Great_white_pelican_%28Pelecanus_onocrotalus%29_head.jpg"},{"n":"Great Hornbill","ord":"Bucerotiformes","fam":"Bucerotidae","ha":"Forests of South and Southeast Asia","di":"Fruit, small animals, insects","si":"94-102 cm","sp":"~40 km/h (25 mph)","ff":"The female seals herself inside a tree cavity for months, fed through a small hole by the male, until chicks hatch.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/45/Great_Hornbill_by_Tisha_Mukherjee_02.jpg/500px-Great_Hornbill_by_Tisha_Mukherjee_02.jpg"},{"n":"Magnificent Bird-of-Paradise","ord":"Passeriformes","fam":"Paradisaeidae","ha":"Hill forests of New Guinea","di":"Fruit, arthropods","si":"19 cm (+ ornamental plumes)","sp":"~30 km/h (19 mph)","ff":"The male clears a display court, then performs an extraordinary dance with iridescent plumes to attract females.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e3/Magnificent_Bird-of-Paradise_0A2A0308.jpg/500px-Magnificent_Bird-of-Paradise_0A2A0308.jpg"},{"n":"Shoebill","ord":"Pelecaniformes","fam":"Balaenicipitidae","ha":"Papyrus swamps of Central Africa","di":"Lungfish, baby crocodiles, small mammals","si":"110-140 cm tall","sp":"~45 km/h (28 mph)","ff":"Strikes with a shoe-shaped bill as wide as a human's foot; stands motionless for hours — nicknamed the 'whalehead stork'.","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/2/24/Balaeniceps_rex_-Ueno_Zoo%2C_Tokyo%2C_Japan-8a.jpg/500px-Balaeniceps_rex_-Ueno_Zoo%2C_Tokyo%2C_Japan-8a.jpg"}]