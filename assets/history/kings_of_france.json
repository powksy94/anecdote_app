[{"n":"Clovis I","dy":"Merovingian","rs":481,"re":511,"ni":"The Great","fa":"First king to unite the Franks, converted to Christianity at Reims","im":"https://upload.wikimedia.org/wikipedia/commons/4/41/Saint_Remy_baptise_Clovis_d%C3%A9tail.jpg"},{"n":"Clotaire I","dy":"Merovingian","rs":511,"re":561,"ni":"The Old","fa":"Reunified the Frankish kingdom after years of division","im":"https://upload.wikimedia.org/wikipedia/commons/c/c5/Monnaie_d%27argent_de_Clotaire_Ier.jpeg","hn":"No portrait of Clotaire I survives. Painted portraiture did not yet exist in 6th-century Francia, so this silver coin is the oldest known contemporary image of him."},{"n":"Chilpéric I","dy":"Merovingian","rs":561,"re":584,"ni":"The Nero of the Franks","fa":"Brutal ruler known for conflicts with his wife Frédégonde","im":"https://upload.wikimedia.org/wikipedia/commons/4/49/Portrait_Roi_de_france_Chilp%C3%A9ric_roy_de_France.jpg"},{"n":"Dagobert I","dy":"Merovingian","rs":629,"re":639,"ni":"The Good King","fa":"Last effective Merovingian king, made Paris his capital","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fd/Tr%C3%A9missis_de_Dagobert_Ier.jpg/500px-Tr%C3%A9missis_de_Dagobert_Ier.jpg"},{"n":"Childéric III","dy":"Merovingian","rs":743,"re":751,"ni":"The Last","fa":"Last Merovingian king, deposed by Pépin le Bref","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/Beaux-Arts_de_Carcassonne_-_Le_dernier_des_M%C3%A9rovingiens_-_Evariste-Vital_Luminais_-Joconde_04400000403.jpg/500px-Beaux-Arts_de_Carcassonne_-_Le_dernier_des_M%C3%A9rovingiens_-_Evariste-Vital_Luminais_-Joconde_04400000403.jpg"},{"n":"Pépin le Bref","dy":"Carolingian","rs":751,"re":768,"ni":"The Short","fa":"First Carolingian king, father of Charlemagne, allied with the Pope","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/64/PippinImperialChronicleCorpusChristiCollegeMS373Fol14.jpg/500px-PippinImperialChronicleCorpusChristiCollegeMS373Fol14.jpg"},{"n":"Charlemagne","dy":"Carolingian","rs":768,"re":814,"ni":"Charles the Great","fa":"Crowned Holy Roman Emperor in 800, unified much of Western Europe","im":"https://upload.wikimedia.org/wikipedia/commons/a/a2/Albrecht_D%C3%BCrer_-_Emperor_Charlemagne_%28cropped%29.jpg"},{"n":"Louis I","dy":"Carolingian","rs":814,"re":840,"ni":"The Pious","fa":"Son of Charlemagne, attempted to maintain the unified empire","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1a/Ludwik_I_Pobo%C5%BCny.jpg/500px-Ludwik_I_Pobo%C5%BCny.jpg"},{"n":"Charles II","dy":"Carolingian","rs":843,"re":877,"ni":"The Bald","fa":"First King of West Francia after the Treaty of Verdun (843)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/40/Biblioth%C3%A8que_nationale_de_France_-_Bible_de_Vivien_Ms._Latin_1_folio_423r_d%C3%A9tail_Le_comte_Vivien_offre_le_manuscrit_de_la_Bible_faite_%C3%A0_l%27abbaye_de_Saint-Martin_de_Tours_%C3%A0_Charles_le_Chauve.jpg/500px-thumbnail.jpg"},{"n":"Louis II","dy":"Carolingian","rs":877,"re":879,"ni":"The Stammerer","fa":"Short reign, son of Charles the Bald","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ad/Denier_sous_Louis_II_dit_le_B%C3%A8gue.jpg/500px-Denier_sous_Louis_II_dit_le_B%C3%A8gue.jpg","hn":"No portrait of Louis II survives from his brief 9th-century reign. This minted coin is the only contemporary depiction historians have of him."},{"n":"Louis III","dy":"Carolingian","rs":879,"re":882,"ni":null,"fa":"Defeated the Vikings at the Battle of Saucourt (881)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/fb/Basilique_de_Saint-Denis_%40_Saint-Denis_%28cropped%29.jpg/500px-Basilique_de_Saint-Denis_%40_Saint-Denis_%28cropped%29.jpg"},{"n":"Carloman II","dy":"Carolingian","rs":879,"re":884,"ni":null,"fa":"Co-ruled with his brother Louis III","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bc/Basilica_di_saint_Denis_Carlomanno_II_di_Francia_%28rotated%29.jpeg/500px-Basilica_di_saint_Denis_Carlomanno_II_di_Francia_%28rotated%29.jpeg"},{"n":"Charles III","dy":"Carolingian","rs":884,"re":888,"ni":"The Fat","fa":"Briefly reunited the Carolingian empire before deposition","im":"https://upload.wikimedia.org/wikipedia/commons/e/ec/Sceau_de_Charles_le_gros.jpg","hn":"No portrait of Charles III survives from his brief 9th-century reign. This royal seal, used to authenticate official documents, is the only surviving contemporary depiction of him."},{"n":"Eudes","dy":"Robertian","rs":888,"re":898,"ni":null,"fa":"Defended Paris against Vikings, first non-Carolingian king","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/50/Coronation_of_Odo.png/500px-Coronation_of_Odo.png"},{"n":"Charles III","dy":"Carolingian","rs":898,"re":922,"ni":"The Simple","fa":"Ceded Normandy to Viking chief Rollo in 911","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0c/Denier_sous_Charles_III_le_Simple.jpg/500px-Denier_sous_Charles_III_le_Simple.jpg","hn":"No portrait of Charles III survives from his early 10th-century reign. This minted coin is the only contemporary depiction historians have of him."},{"n":"Robert I","dy":"Robertian","rs":922,"re":923,"ni":null,"fa":"Elected king by rebellious nobles, killed in battle","im":"https://upload.wikimedia.org/wikipedia/commons/5/5a/Robert_Ier_roi_des_Francs.jpg"},{"n":"Raoul","dy":"Burgundian","rs":923,"re":936,"ni":null,"fa":"Defended against Magyar and Viking invasions","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/ba/King_Rudolph_of_France.jpg/330px-King_Rudolph_of_France.jpg"},{"n":"Louis IV","dy":"Carolingian","rs":936,"re":954,"ni":"Overseas","fa":"Raised in England, struggled to reclaim royal authority","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/8b/Louis_IV_denier_Chinon_936_954.jpg/500px-Louis_IV_denier_Chinon_936_954.jpg","hn":"No portrait of Louis IV survives from his mid-10th-century reign. This minted coin is the only contemporary depiction historians have of him."},{"n":"Lothaire","dy":"Carolingian","rs":954,"re":986,"ni":null,"fa":"Last powerful Carolingian king of West Francia","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/b3/T%C3%AAte_de_la_statue_du_roi_Lothaire_fab_en_1140.JPG/500px-T%C3%AAte_de_la_statue_du_roi_Lothaire_fab_en_1140.JPG"},{"n":"Louis V","dy":"Carolingian","rs":986,"re":987,"ni":"The Sluggard","fa":"Last Carolingian king, died without heir","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d5/Louis_V_of_France_in_the_Bibliotheque.jpg/500px-Louis_V_of_France_in_the_Bibliotheque.jpg"},{"n":"Hugues Capet","dy":"Capetian","rs":987,"re":996,"ni":null,"fa":"Founded the Capetian dynasty, which ruled France for 341 years","im":"https://upload.wikimedia.org/wikipedia/commons/6/65/SceauHuguesCapet_%28cropped%29.PNG","hn":"No portrait of Hugues Capet survives. This royal seal, used to authenticate official documents, is the oldest known depiction of the founder of the Capetian dynasty."},{"n":"Robert II","dy":"Capetian","rs":996,"re":1031,"ni":"The Pious","fa":"Known for his piety, excommunicated by the Pope","im":"https://upload.wikimedia.org/wikipedia/commons/9/9f/Sceau_de_Robert_II_le_pieux.jpg","hn":"No portrait of Robert II survives from his reign. This royal seal, used to authenticate official documents, is the only surviving contemporary depiction of him."},{"n":"Henri I","dy":"Capetian","rs":1031,"re":1060,"ni":null,"fa":"Allied with William the Conqueror before their falling out","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/4b/Sceau_du_roi_Henri_Ier.jpg/500px-Sceau_du_roi_Henri_Ier.jpg","hn":"No portrait of Henri I survives from his reign. This royal seal, used to authenticate official documents, is the only surviving contemporary depiction of him."},{"n":"Philippe I","dy":"Capetian","rs":1060,"re":1108,"ni":"The Amorous","fa":"First French king to be excommunicated for adultery","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0d/Sceau_du_roi_Philippe_Ier.jpg/500px-Sceau_du_roi_Philippe_Ier.jpg","hn":"No portrait of Philippe I survives from his reign. This royal seal, used to authenticate official documents, is the only surviving contemporary depiction of him."},{"n":"Louis VI","dy":"Capetian","rs":1108,"re":1137,"ni":"The Fat","fa":"Consolidated royal power and fought feudal lords","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/f/f7/Louis_VI_of_France.jpg/500px-Louis_VI_of_France.jpg"},{"n":"Louis VII","dy":"Capetian","rs":1137,"re":1180,"ni":"The Young","fa":"Led the Second Crusade, divorced Eleanor of Aquitaine","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/3/3b/Louis_7.jpg/500px-Louis_7.jpg"},{"n":"Philippe II","dy":"Capetian","rs":1180,"re":1223,"ni":"Augustus","fa":"Doubled French territory, defeated England at Bouvines (1214)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/dc/Sceau_de_Philippe_Auguste._-_Archives_Nationales_-_SC-D157.jpg/500px-Sceau_de_Philippe_Auguste._-_Archives_Nationales_-_SC-D157.jpg","hn":"No portrait of Philippe II survives from his early reign. This royal seal, used to authenticate official documents, is the oldest known depiction of him."},{"n":"Louis VIII","dy":"Capetian","rs":1223,"re":1226,"ni":"The Lion","fa":"Invaded England, led the Albigensian Crusade","im":"https://upload.wikimedia.org/wikipedia/commons/1/18/Louis8.jpg"},{"n":"Louis IX","dy":"Capetian","rs":1226,"re":1270,"ni":"Saint Louis","fa":"Led two crusades, canonized in 1297, model of Christian kingship","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/de/Saintlouis_%28cropped%29.jpg/500px-Saintlouis_%28cropped%29.jpg"},{"n":"Philippe III","dy":"Capetian","rs":1270,"re":1285,"ni":"The Bold","fa":"Expanded French territory through diplomacy and inheritance","im":"https://upload.wikimedia.org/wikipedia/commons/3/32/Philip_III_of_France.jpg"},{"n":"Philippe IV","dy":"Capetian","rs":1285,"re":1314,"ni":"The Fair","fa":"Suppressed the Knights Templar, moved the papacy to Avignon","im":"https://upload.wikimedia.org/wikipedia/commons/9/98/Philip_iv_and_family._2_%28detail_crop%29.jpg"},{"n":"Louis X","dy":"Capetian","rs":1314,"re":1316,"ni":"The Quarrelsome","fa":"First king to free serfs in France","im":"https://upload.wikimedia.org/wikipedia/commons/3/30/Ludv%C3%ADk_X.png"},{"n":"Philippe V","dy":"Capetian","rs":1316,"re":1322,"ni":"The Tall","fa":"Established the Salic Law excluding women from succession","im":"https://upload.wikimedia.org/wikipedia/commons/c/c5/Sacre_Philippe5_France_01_%28cropped%29.jpg"},{"n":"Charles IV","dy":"Capetian","rs":1322,"re":1328,"ni":"The Fair","fa":"Last direct Capetian king, died without male heir","im":"https://upload.wikimedia.org/wikipedia/commons/3/31/Charles4_mini.jpg"},{"n":"Philippe VI","dy":"Valois","rs":1328,"re":1350,"ni":"The Fortunate","fa":"First Valois king, defeated at Crécy (1346) during the Hundred Years War","im":"https://upload.wikimedia.org/wikipedia/commons/9/93/Phil6france.jpg"},{"n":"Jean II","dy":"Valois","rs":1350,"re":1364,"ni":"The Good","fa":"Captured by the English at Poitiers (1356), held for ransom","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/55/Jean_II_Le_Bon_-_BnF_-_Mus%C3%A9e_du_Louvre_Peinures_RF_2490.jpg/500px-Jean_II_Le_Bon_-_BnF_-_Mus%C3%A9e_du_Louvre_Peinures_RF_2490.jpg"},{"n":"Charles V","dy":"Valois","rs":1364,"re":1380,"ni":"The Wise","fa":"Rebuilt France after English defeats, reorganized the army","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/4a/Saint-Denis_%2893%29%2C_basilique%2C_gisant_de_Charles_V_sculpt%C3%A9_lorsqu%27il_avait_27_ans_2.jpg/500px-Saint-Denis_%2893%29%2C_basilique%2C_gisant_de_Charles_V_sculpt%C3%A9_lorsqu%27il_avait_27_ans_2.jpg"},{"n":"Charles VI","dy":"Valois","rs":1380,"re":1422,"ni":"The Mad","fa":"Suffered from mental illness, signed Treaty of Troyes ceding France to England","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/0a/Charles_VI_de_France_-_Dialogues_de_Pierre_Salmon_-_Bib_de_Gen%C3%A8ve_MsFr165f4.jpg/500px-Charles_VI_de_France_-_Dialogues_de_Pierre_Salmon_-_Bib_de_Gen%C3%A8ve_MsFr165f4.jpg"},{"n":"Charles VII","dy":"Valois","rs":1422,"re":1461,"ni":"The Victorious","fa":"Aided by Joan of Arc, expelled the English and ended Hundred Years War","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/71/KarlVII.jpg/500px-KarlVII.jpg"},{"n":"Louis XI","dy":"Valois","rs":1461,"re":1483,"ni":"The Prudent","fa":"Masterful politician nicknamed 'the Universal Spider', unified France","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1b/Louis_XI_%281423-1483%29.jpg/330px-Louis_XI_%281423-1483%29.jpg"},{"n":"Charles VIII","dy":"Valois","rs":1483,"re":1498,"ni":"The Affable","fa":"Invaded Italy in 1494, starting the Italian Wars","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/6/6f/Portrait_of_King_Charles_VIII_of_France_%281470%E2%80%931498%29%2C_by_anonymous_artist%2C_16th_century_%28cropped%29_2.jpg/500px-Portrait_of_King_Charles_VIII_of_France_%281470%E2%80%931498%29%2C_by_anonymous_artist%2C_16th_century_%28cropped%29_2.jpg"},{"n":"Louis XII","dy":"Valois-Orléans","rs":1498,"re":1515,"ni":"Father of the People","fa":"Reduced taxes, reformed justice, continued Italian campaigns","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/84/Ludwig_XII._von_Frankreich.jpg/330px-Ludwig_XII._von_Frankreich.jpg"},{"n":"François I","dy":"Valois-Angoulême","rs":1515,"re":1547,"ni":"The Father of Letters","fa":"Renaissance patron, invited Leonardo da Vinci, built Château de Chambord","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/8/87/Fran%C3%A7ois_Ier_Louvre.jpg/500px-Fran%C3%A7ois_Ier_Louvre.jpg"},{"n":"Henri II","dy":"Valois-Angoulême","rs":1547,"re":1559,"ni":null,"fa":"Persecuted Protestants, died in a jousting accident","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Henry_II_of_France-Fran%C3%A7ois_Clouet_%28altered%29.jpg/500px-Henry_II_of_France-Fran%C3%A7ois_Clouet_%28altered%29.jpg"},{"n":"François II","dy":"Valois-Angoulême","rs":1559,"re":1560,"ni":null,"fa":"Brief reign at 15, husband of Mary Queen of Scots","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/b/bf/Portrait_du_roi_de_France_Fran%C3%A7ois_II.jpg/500px-Portrait_du_roi_de_France_Fran%C3%A7ois_II.jpg"},{"n":"Charles IX","dy":"Valois-Angoulême","rs":1560,"re":1574,"ni":null,"fa":"Ordered the St. Bartholomew's Day Massacre (1572)","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/Portrait_of_King_Charles_IX_of_France_%281550%E2%80%931574%29%2C_by_After_Fran%C3%A7ois_Clouet.jpg/500px-Portrait_of_King_Charles_IX_of_France_%281550%E2%80%931574%29%2C_by_After_Fran%C3%A7ois_Clouet.jpg"},{"n":"Henri III","dy":"Valois-Angoulême","rs":1574,"re":1589,"ni":null,"fa":"Last Valois king, assassinated by a monk","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/7f/Quesnel_Henry_III_of_France_in_Polish_hat.jpg/500px-Quesnel_Henry_III_of_France_in_Polish_hat.jpg"},{"n":"Henri IV","dy":"Bourbon","rs":1589,"re":1610,"ni":"Good King Henry","fa":"Ended Wars of Religion, issued Edict of Nantes, assassinated by Ravaillac","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/4/4f/Frans_Pourbus_the_Younger_%28Antwerp_1569_-_Paris_1622%29_-_Henri_IV%2C_King_of_France_%281553-1610%29_-_RCIN_402972_-_Royal_Collection.jpg/500px-Frans_Pourbus_the_Younger_%28Antwerp_1569_-_Paris_1622%29_-_Henri_IV%2C_King_of_France_%281553-1610%29_-_RCIN_402972_-_Royal_Collection.jpg"},{"n":"Louis XIII","dy":"Bourbon","rs":1610,"re":1643,"ni":"The Just","fa":"Relied on Cardinal Richelieu, strengthened absolute monarchy","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/1/1b/Luis_XIII%2C_rey_de_Francia_%28Philippe_de_Champaigne%29.jpg/500px-Luis_XIII%2C_rey_de_Francia_%28Philippe_de_Champaigne%29.jpg"},{"n":"Louis XIV","dy":"Bourbon","rs":1643,"re":1715,"ni":"The Sun King","fa":"Longest reign in European history (72 yrs), built Versailles, peak of French power","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/5/5f/Louis_XIV_of_France.jpg/330px-Louis_XIV_of_France.jpg"},{"n":"Louis XV","dy":"Bourbon","rs":1715,"re":1774,"ni":"The Well-Beloved","fa":"Lost Canada and India to Britain, laid groundwork for Revolution","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/c6/Louis_XV%2C_King_of_France_%281710-1774%29_edited_2.jpg/330px-Louis_XV%2C_King_of_France_%281710-1774%29_edited_2.jpg"},{"n":"Louis XVI","dy":"Bourbon","rs":1774,"re":1792,"ni":null,"fa":"Last king before the Revolution, executed by guillotine on 21 January 1793","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/Antoine-Fran%C3%A7ois_Callet_-_Louis_XVI%2C_roi_de_France_et_de_Navarre_%281754-1793%29%2C_rev%C3%AAtu_du_grand_costume_royal_en_1779_-_Google_Art_Project.jpg/500px-Antoine-Fran%C3%A7ois_Callet_-_Louis_XVI%2C_roi_de_France_et_de_Navarre_%281754-1793%29%2C_rev%C3%AAtu_du_grand_costume_royal_en_1779_-_Google_Art_Project.jpg"},{"n":"Louis XVIII","dy":"Bourbon","rs":1814,"re":1824,"ni":"The Desired","fa":"Restored after Napoleon, established constitutional monarchy","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/7/77/G%C3%A9rard_-_Louis_XVIII_of_France_in_Coronation_Robes.jpg/330px-G%C3%A9rard_-_Louis_XVIII_of_France_in_Coronation_Robes.jpg"},{"n":"Charles X","dy":"Bourbon","rs":1824,"re":1830,"ni":null,"fa":"Absolutist policies provoked the July Revolution, last Bourbon king to reign","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/d/d0/Carlos_X_de_Francia_%28Fran%C3%A7ois_G%C3%A9rard%29.jpg/500px-Carlos_X_de_Francia_%28Fran%C3%A7ois_G%C3%A9rard%29.jpg"},{"n":"Louis-Philippe I","dy":"Orléans","rs":1830,"re":1848,"ni":"The Citizen King","fa":"Last king of France, overthrown by 1848 Revolution","im":"https://upload.wikimedia.org/wikipedia/commons/thumb/0/06/1841_portrait_painting_of_Louis_Philippe_I_%28King_of_the_French%29_by_Winterhalter.jpg/330px-1841_portrait_painting_of_Louis_Philippe_I_%28King_of_the_French%29_by_Winterhalter.jpg"}]